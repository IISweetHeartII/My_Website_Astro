# Site Configuration
SITE_URL=https://log8.kr

# Node Environment
NODE_ENV=production

# Google Tag Manager (빌드 타임에 주입됨, PUBLIC_ prefix 필수)
# Cloudflare Dashboard에도 동일하게 설정 필요
PUBLIC_GTM_ID=GTM-XXXXXXXXX

# AI Chatbot (Cloudflare Pages Functions 런타임 환경변수)
# 로컬 개발: .dev.vars에 설정 / 프로덕션: Cloudflare Dashboard에서 설정
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
