# Site Configuration
SITE_URL=https://log8.kr

# Node Environment
NODE_ENV=production

# Google Analytics 4 (빌드 타임에 주입됨, PUBLIC_ prefix 필수)
# Cloudflare Dashboard에도 동일하게 설정 필요
PUBLIC_GA_ID=G-XXXXXXXXXX

# === 아래 항목은 Cloudflare Pages Functions 런타임 환경변수 ===
# 로컬 개발: .dev.vars에 설정 / 프로덕션: Cloudflare Dashboard에서 설정

# AI Chatbot
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# Chat Admin API 보호용 시크릿
# ADMIN_SECRET=your-random-secret

# Cloudflare KV (wrangler.toml에서 바인딩, Dashboard에서도 바인딩 필요)
# CHAT_KV는 KV namespace 바인딩으로 설정 (환경변수 아님)
