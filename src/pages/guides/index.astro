---
import { getCollection } from "astro:content";
import { ArrowRight, BookOpen, Clock3, Sparkles } from "lucide-astro";
import Layout from "@/layouts/Layout.astro";
import BreadcrumbSchema from "@/shared/components/seo/BreadcrumbSchema.astro";
import { SITE_URL } from "@/shared/config/consts";

const allGuides = await getCollection("guides");
const guides = allGuides
  .filter((guide) => guide.data.publish && !guide.data.draft)
  .sort((a, b) => b.data.updatedDate.getTime() - a.data.updatedDate.getTime());

const formatDate = (date: Date) => date.toISOString().slice(0, 10);
const getSlug = (id: string, slug?: string | null) => slug ?? id.replace(/\.[^/.]+$/, "");

const pageTitle = "Guides";
const pageDescription =
  "AI 도구와 운영 시스템을 실제로 구축하고 운용하는 사람을 위한 결정판 가이드 모음입니다.";

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE_URL}/guides/#collection`,
  name: pageTitle,
  description: pageDescription,
  url: `${SITE_URL}/guides/`,
  isPartOf: { "@id": `${SITE_URL}/#website` },
  inLanguage: "ko-KR",
  numberOfItems: guides.length,
};
---

<Layout title={pageTitle} description={pageDescription} og_type="website">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionPageSchema)} />
    <BreadcrumbSchema items={[
      { name: "홈", url: "/" },
      { name: "Guides", url: "/guides/" },
    ]} />
  </Fragment>

  <div class="mx-auto w-full max-w-6xl p-6 md:p-8">
    <header class="mb-10 overflow-hidden rounded-3xl border border-background-lighter bg-background px-6 py-8 shadow-sm md:px-8 md:py-10">
      <div class="pointer-events-none absolute inset-0" />
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_300px] lg:items-end">
        <div>
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-2 text-sm font-semibold text-primary">
            <Sparkles class="h-4 w-4" strokeWidth={2.2} />
            Complete guides
          </div>
          <h1 class="text-4xl font-extrabold tracking-tight text-text md:text-5xl">Guides</h1>
          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-text-light">
            {pageDescription} 짧은 뉴스가 아니라, 한 페이지에서 설치·운영·검증·FAQ까지 끝내는 살아있는 문서입니다.
          </p>
        </div>

        <div class="rounded-3xl border border-background-lighter bg-background-light p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-muted">Guide library</p>
          <p class="mt-2 text-3xl font-bold text-text">{guides.length}</p>
          <p class="mt-1 text-sm text-text-light">versioned long-form guides</p>
        </div>
      </div>
    </header>

    {guides.length > 0 ? (
      <section class="grid gap-5 md:grid-cols-2">
        {guides.map((guide) => {
          const slug = getSlug(guide.id, guide.data.slug);
          return (
            <a
              href={`/guides/${slug}/`}
              class="group relative overflow-hidden rounded-3xl border border-background-lighter bg-background p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/25 hover:shadow-xl"
            >
              <div class="pointer-events-none absolute inset-0 bg-linear-to-br from-primary/8 via-transparent to-accent/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
              <div class="relative">
                <div class="mb-4 flex flex-wrap items-center gap-2">
                  <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
                    <BookOpen class="h-3.5 w-3.5" strokeWidth={2.2} />
                    Guide v{guide.data.guideVersion}
                  </span>
                  {guide.data.draft && (
                    <span class="rounded-full border border-accent/20 bg-accent/10 px-3 py-1 text-xs font-semibold text-accent">
                      Draft
                    </span>
                  )}
                </div>

                <h2 class="text-2xl font-bold leading-tight text-text transition-colors duration-300 group-hover:text-primary">
                  {guide.data.title}
                </h2>
                {guide.data.description && (
                  <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-text-light">
                    {guide.data.description}
                  </p>
                )}

                <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-text-muted">
                  <span>Last updated: {formatDate(guide.data.updatedDate)}</span>
                  {guide.data.reading_time && (
                    <span class="inline-flex items-center gap-1.5">
                      <Clock3 class="h-3.5 w-3.5 text-primary" strokeWidth={2} />
                      {guide.data.reading_time}분 읽기
                    </span>
                  )}
                  {guide.data.toolVersion && <span>{guide.data.toolVersion}</span>}
                </div>

                <div class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-300 group-hover:gap-2.5 group-hover:text-accent">
                  <span>가이드 열기</span>
                  <ArrowRight class="h-4 w-4" strokeWidth={2.5} />
                </div>
              </div>
            </a>
          );
        })}
      </section>
    ) : (
      <div class="rounded-3xl border border-dashed border-background-lighter bg-background-light px-6 py-16 text-center">
        <BookOpen class="mx-auto mb-4 h-14 w-14 text-text-muted/35" strokeWidth={1.5} />
        <p class="text-lg font-medium text-text">아직 준비 중인 가이드가 없습니다.</p>
      </div>
    )}
  </div>
</Layout>
