---
import { Image } from "astro:assets";
import { FileText, Github } from "lucide-astro";
import profileImage from "@/assets/images/design/DH_ID.jpg";
import { SITE_TITLE } from "@/shared/config/consts";
import { getUrl } from "@/shared/utils/url";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title={`Portfolio - ${SITE_TITLE}`}
  description="김덕환의 포트폴리오 - 기술로 감동과 사랑을 전하는 개발자"
>
  <main class="portfolio-root max-w-[1600px] mx-auto px-6 py-16 bg-background print:max-w-full print:p-0 print:m-0 print:bg-white">
    <!-- Resume Link Banner -->
    <div class="mb-6 p-4 bg-primary/10 rounded-lg border border-primary/20 flex justify-between items-center">
      <span class="text-sm text-text-light">1-2페이지 압축 버전을 원하시나요?</span>
      <a
        href={getUrl("/resume")}
        class="flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-light"
      >
        <FileText class="w-4 h-4" />
        Resume 보기 (PDF 저장 가능)
      </a>
    </div>

    <section class="portfolio-controls mb-6 p-4 bg-background rounded-lg border border-background-lighter print:hidden">
      <div class="flex flex-wrap items-center gap-2 justify-between">
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-text-light">Project Page</span>
          <button
            type="button"
            id="prev-project-btn"
            class="rounded-md border border-background-lighter bg-background px-3 py-1.5 text-sm font-medium text-text-light"
          >
            이전 프로젝트
          </button>
          <span id="project-page-indicator" class="text-xs font-semibold text-text-light min-w-[72px] text-center">1 / 1</span>
          <button
            type="button"
            id="next-project-btn"
            class="rounded-md border border-background-lighter bg-background px-3 py-1.5 text-sm font-medium text-text-light"
          >
            다음 프로젝트
          </button>
        </div>
        <button
          type="button"
          id="print-portfolio-btn"
          class="rounded-md border border-primary bg-primary px-3 py-1.5 text-sm font-semibold text-on-primary"
        >
          PDF 출력
        </button>
      </div>
    </section>

    <!-- Header -->
    <header class="mb-14 p-8 bg-background rounded-lg shadow-sm border-l-4 border-primary">
      <div class="flex justify-between items-center gap-8 flex-col md:flex-row">
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-3 text-text">김덕환</h1>
          <p class="text-xl md:text-2xl font-semibold text-primary mb-5">
            감동과 사랑을 전하는 '기술 번역가'
          </p>
          <p class="text-base text-text-light leading-relaxed">
            사용자의 감정과 니즈를 이해하고, 진정한 가치를 전달하는 개발자입니다.
          </p>
        </div>
        <div class="shrink-0">
          <Image
            src={profileImage}
            alt="김덕환 프로필 사진"
            class="w-36 h-auto object-cover rounded-lg border-3 border-primary shadow-md md:w-40"
            width={413}
            height={531}
          />
        </div>
      </div>
    </header>

    <!-- Contact -->
    <section class="mb-14 p-8 bg-background rounded-lg shadow-sm">
      <h2 class="text-2xl md:text-3xl font-bold mb-6 pb-3 border-b-2 border-background-lighter text-text">
        Contact
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div
          class="flex flex-col gap-2 p-4 bg-background-light rounded-md border-l-3 border-primary hover:bg-background-lighter hover:-translate-y-0.5 transition-all"
        >
          <span class="text-xs font-bold uppercase text-text-light tracking-wide">Email</span>
          <a
            href="mailto:sachi009955@gmail.com"
            class="text-primary font-medium hover:text-primary-light"
          >
            sachi009955@gmail.com
          </a>
        </div>
        <div
          class="flex flex-col gap-2 p-4 bg-background-light rounded-md border-l-3 border-primary hover:bg-background-lighter hover:-translate-y-0.5 transition-all"
        >
          <span class="text-xs font-bold uppercase text-text-light tracking-wide">GitHub</span>
          <a
            href="https://github.com/IISweetHeartII"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary font-medium hover:text-primary-light"
          >
            github.com/IISweetHeartII
          </a>
        </div>
        <div
          class="flex flex-col gap-2 p-4 bg-background-light rounded-md border-l-3 border-primary hover:bg-background-lighter hover:-translate-y-0.5 transition-all"
        >
          <span class="text-xs font-bold uppercase text-text-light tracking-wide">Blog</span>
          <a
            href="https://log8.kr"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary font-medium hover:text-primary-light"
          >
            log8.kr
          </a>
        </div>
      </div>
    </section>

    <!-- Profile -->
    <section id="tech-stack" class="mb-14 p-8 bg-background rounded-lg shadow-sm">
      <h2 class="text-2xl md:text-3xl font-bold mb-6 pb-3 border-b-2 border-background-lighter text-text">
        Profile
      </h2>
      <div class="bg-background-light p-6 rounded-md border-l-4 border-primary">
        <p class="text-base text-text leading-relaxed">
          저는 '신뢰할 수 있는 기술 번역가'로서 사용자의 감정과 니즈를 이해하고, 이를 기술로
          번역하여 진정한 가치를 전달하는 것을 목표로 합니다. 단순히 기능을 구현하는 것을 넘어,
          사용자에게 감동과 사랑을 전하는 서비스를 만들고 싶습니다.
        </p>
        <p class="text-base text-text leading-relaxed mt-4">
          호기심으로 살아갑니다. 예전에는 궁금한 것을 해결하는 데 많은 시간과 노력이 들었지만,
          지금은 AI 덕분에 레버리지를 활용하여 '내가 이렇게 많이 알아도 되나?'싶을 정도로 다양한
          분야의 지식을 빠르게 습득하고 실험하고 있습니다.
        </p>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="mb-14 p-8 bg-background rounded-lg shadow-sm">
      <h2 class="text-2xl md:text-3xl font-bold mb-6 pb-3 border-b-2 border-background-lighter text-text">
        Tech Stack
      </h2>

      <!-- Languages -->
      <div class="mb-8">
        <h3 class="text-lg font-bold text-text mb-4 pl-3 border-l-3 border-primary">
          Languages
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2.5">
          {
            [
              { name: "Python", stars: 4, level: "Advanced" },
              { name: "C++", stars: 3, level: "Intermediate" },
            ].map((tech) => (
              <div class="flex justify-between items-center px-4 py-3.5 bg-background-light rounded-md border border-background-lighter hover:bg-background hover:border-primary hover:translate-x-1 transition-all">
                <span class="text-base font-semibold text-text">{tech.name}</span>
                <div class="flex items-center gap-4">
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }, (_, i) => (
                      <span
                        class={`text-base ${i < tech.stars ? "text-primary-light" : "text-background-lighter"}`}
                      >
                        ★
                      </span>
                    ))}
                  </div>
                  <span class="text-xs font-semibold text-on-primary bg-primary px-2.5 py-1 rounded-full min-w-[85px] text-center">
                    {tech.level}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Frontend -->
      <div class="mb-8">
        <h3 class="text-lg font-bold text-text mb-4 pl-3 border-l-3 border-primary">
          Frontend
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2.5">
          {
            [
              { name: "Next.js", stars: 4, level: "Advanced" },
              { name: "Astro", stars: 4, level: "Advanced" },
            ].map((tech) => (
              <div class="flex justify-between items-center px-4 py-3.5 bg-background-light rounded-md border border-background-lighter hover:bg-background hover:border-primary hover:translate-x-1 transition-all">
                <span class="text-base font-semibold text-text">{tech.name}</span>
                <div class="flex items-center gap-4">
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }, (_, i) => (
                      <span
                        class={`text-base ${i < tech.stars ? "text-primary-light" : "text-background-lighter"}`}
                      >
                        ★
                      </span>
                    ))}
                  </div>
                  <span class="text-xs font-semibold text-on-primary bg-primary px-2.5 py-1 rounded-full min-w-[85px] text-center">
                    {tech.level}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Backend -->
      <div class="mb-8">
        <h3 class="text-lg font-bold text-text mb-4 pl-3 border-l-3 border-primary">
          Backend
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2.5">
          {
            [
              { name: "Node.js", stars: 3, level: "Intermediate" },
              { name: "Spring Boot", stars: 2, level: "Beginner" },
              { name: "PostgreSQL", stars: 3, level: "Intermediate" },
            ].map((tech) => (
              <div class="flex justify-between items-center px-4 py-3.5 bg-background-light rounded-md border border-background-lighter hover:bg-background hover:border-primary hover:translate-x-1 transition-all">
                <span class="text-base font-semibold text-text">{tech.name}</span>
                <div class="flex items-center gap-4">
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }, (_, i) => (
                      <span
                        class={`text-base ${i < tech.stars ? "text-primary-light" : "text-background-lighter"}`}
                      >
                        ★
                      </span>
                    ))}
                  </div>
                  <span class="text-xs font-semibold text-on-primary bg-primary px-2.5 py-1 rounded-full min-w-[85px] text-center">
                    {tech.level}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Deployment -->
      <div class="mb-8">
        <h3 class="text-lg font-bold text-text mb-4 pl-3 border-l-3 border-primary">
          Deployment
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2.5">
          {
            [
              { name: "Vercel", stars: 4, level: "Advanced" },
              { name: "Cloudflare", stars: 3, level: "Intermediate" },
            ].map((tech) => (
              <div class="flex justify-between items-center px-4 py-3.5 bg-background-light rounded-md border border-background-lighter hover:bg-background hover:border-primary hover:translate-x-1 transition-all">
                <span class="text-base font-semibold text-text">{tech.name}</span>
                <div class="flex items-center gap-4">
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }, (_, i) => (
                      <span
                        class={`text-base ${i < tech.stars ? "text-primary-light" : "text-background-lighter"}`}
                      >
                        ★
                      </span>
                    ))}
                  </div>
                  <span class="text-xs font-semibold text-on-primary bg-primary px-2.5 py-1 rounded-full min-w-[85px] text-center">
                    {tech.level}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- CI/CD & DevOps -->
      <div class="mb-8">
        <h3 class="text-lg font-bold text-text mb-4 pl-3 border-l-3 border-primary">
          CI/CD & DevOps
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2.5">
          {
            [
              { name: "CI/CD 구축", stars: 4, level: "Advanced" },
              { name: "Docker", stars: 2, level: "Beginner" },
            ].map((tech) => (
              <div class="flex justify-between items-center px-4 py-3.5 bg-background-light rounded-md border border-background-lighter hover:bg-background hover:border-primary hover:translate-x-1 transition-all">
                <span class="text-base font-semibold text-text">{tech.name}</span>
                <div class="flex items-center gap-4">
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }, (_, i) => (
                      <span
                        class={`text-base ${i < tech.stars ? "text-primary-light" : "text-background-lighter"}`}
                      >
                        ★
                      </span>
                    ))}
                  </div>
                  <span class="text-xs font-semibold text-on-primary bg-primary px-2.5 py-1 rounded-full min-w-[85px] text-center">
                    {tech.level}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Collaboration -->
      <div class="mb-8">
        <h3 class="text-lg font-bold text-text mb-4 pl-3 border-l-3 border-primary">
          Collaboration
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2.5">
          {
            [{ name: "GitHub", stars: 5, level: "Expert" }].map((tech) => (
              <div class="flex justify-between items-center px-4 py-3.5 bg-background-light rounded-md border border-background-lighter hover:bg-background hover:border-primary hover:translate-x-1 transition-all">
                <span class="text-base font-semibold text-text">{tech.name}</span>
                <div class="flex items-center gap-4">
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }, (_, i) => (
                      <span
                        class={`text-base ${i < tech.stars ? "text-primary-light" : "text-background-lighter"}`}
                      >
                        ★
                      </span>
                    ))}
                  </div>
                  <span class="text-xs font-semibold text-on-primary bg-primary px-2.5 py-1 rounded-full min-w-[85px] text-center">
                    {tech.level}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- AI Tools -->
      <div class="mb-0">
        <h3 class="text-lg font-bold text-text mb-4 pl-3 border-l-3 border-primary">
          AI Tools
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2.5">
          {
            [
              { name: "Claude Code", stars: 5, level: "Expert" },
              { name: "LangChain", stars: 2, level: "Beginner" },
            ].map((tech) => (
              <div class="flex justify-between items-center px-4 py-3.5 bg-background-light rounded-md border border-background-lighter hover:bg-background hover:border-primary hover:translate-x-1 transition-all">
                <span class="text-base font-semibold text-text">{tech.name}</span>
                <div class="flex items-center gap-4">
                  <div class="flex gap-0.5">
                    {Array.from({ length: 5 }, (_, i) => (
                      <span
                        class={`text-base ${i < tech.stars ? "text-primary-light" : "text-background-lighter"}`}
                      >
                        ★
                      </span>
                    ))}
                  </div>
                  <span class="text-xs font-semibold text-on-primary bg-primary px-2.5 py-1 rounded-full min-w-[85px] text-center">
                    {tech.level}
                  </span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section id="portfolio-projects-section" class="mb-14 p-8 bg-background rounded-lg shadow-sm portfolio-projects-section">
      <h2 class="text-2xl md:text-3xl font-bold mb-6 pb-3 border-b-2 border-background-lighter text-text">
        Projects
      </h2>

      <!-- 1. Finders -->
      <div
        id="finders"
        class="mb-7 p-7 bg-background-light rounded-lg border border-l-4 border-primary hover:shadow-md hover:-translate-y-1 transition-all md:border-l-0 md:border-t-4 scroll-mt-20 portfolio-project-card is-active"
      >
        <div class="mb-5 pb-4 border-b-2 border-background-lighter">
          <h3 class="text-xl font-bold text-text mb-2.5">BE Lead로 GCP 인프라 구축 및 팀 코드 리뷰 문화 정착</h3>
          <p class="text-sm text-text-light mb-2">Finders - 필름 현상소 연결 플랫폼</p>
          <div class="flex gap-4 text-sm text-text-light">
            <span>2025.12 - 현재</span>
            <span>Backend Lead (11명 팀, BE 5명)</span>
          </div>
        </div>

        <p class="text-base text-text leading-relaxed mb-6">
          필름 카메라 사용자를 위한 현상소 검색·예약·사진 공유 플랫폼.
          UMC 9기 프로젝트로 BE Lead를 맡아 아키텍처 설계, 코드 리뷰 문화 정착, GCP 인프라 구축을 담당.
        </p>

        <div class="mb-6 p-5 bg-background rounded-md border-l-4 border-blue-500">
          <h4 class="text-sm font-bold text-blue-600 uppercase tracking-wide mb-3">기술적 도전</h4>
          <div class="space-y-3 text-sm">
            <div>
              <span class="font-semibold text-text">문제:</span>
              <span class="text-text-light"> 5명 BE 개발자의 코드 품질 불일치, AWS 대비 예산 제약</span>
            </div>
            <div>
              <span class="font-semibold text-text">해결:</span>
              <span class="text-text-light"> GCP $300 크레딧 활용, CODE_STYLE.md 문서화, PR마다 코드 리뷰 의무화</span>
            </div>
            <div>
              <span class="font-semibold text-text">결과:</span>
              <span class="text-text-light"> 코드 리뷰 빈도 400% 증가(약 5배), Terraform IaC로 복구 시간 56h → 5h 단축</span>
            </div>
          </div>
        </div>

        <div class="mb-6 p-5 bg-background-light rounded-md border-l-4 border-emerald-500">
          <h4 class="text-sm font-bold text-emerald-600 uppercase tracking-wide mb-3">AI 활용</h4>
          <ul class="list-disc list-inside text-sm text-text space-y-2">
            <li>Stable Diffusion Inpainting API 연동 - 필름 빛번짐(Light Leak) 복원 기능</li>
            <li>Claude Code로 기존 ThreadPool 코드를 Java 21 Virtual Threads로 마이그레이션</li>
            <li>GCP VPC 네트워크 설계, IAP SSH 터널링으로 보안 DB 접속 환경 구축</li>
            <li>포트원(PortOne) 결제 시스템 연동 - 예약 → 결제 → 확정 플로우 설계</li>
          </ul>
        </div>

        <div class="mb-6">
          <div class="flex flex-wrap gap-2">
            {
              ["Java 21", "Spring Boot 3.4", "MySQL", "QueryDSL", "GCP", "Terraform", "Docker"].map(
                (tag) => (
                  <span class="px-3.5 py-1.5 bg-primary text-on-primary text-xs font-semibold rounded-full">
                    {tag}
                  </span>
                )
              )
            }
          </div>
        </div>

        <div class="p-4 bg-background-light rounded-md overflow-x-auto">
          <h4 class="text-sm font-bold text-text-light uppercase tracking-wide mb-3">GCP 인프라 아키텍처</h4>
          <pre class="mermaid text-sm">
flowchart TB
    subgraph Client["클라이언트"]
        A[Next.js App]
    end

    subgraph GCP["Google Cloud Platform"]
        subgraph Compute["Compute Engine"]
            B1[Main Instance]
            B2[Dev Instance]
        end
        C[(Cloud SQL - MySQL)]
        D[Cloud Storage]
        E[Cloud Vision AI]
    end

    subgraph External["외부 서비스"]
        F[Stable Diffusion API]
        G[PortOne 결제]
    end

    A --> B1
    A --> B2
    B1 --> C
    B2 --> C
    B1 --> D
    B1 --> E
    B1 --> F
    B1 --> G
          </pre>
        </div>

        <div class="mt-5 pt-5 border-t-2 border-background-lighter">
          <a
            href="https://github.com/Finders-Official/BE"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4.5 py-2.5 bg-text text-on-primary text-sm font-semibold rounded-md hover:bg-primary hover:-translate-y-0.5 hover:shadow-md transition-all"
          >
            <Github class="w-4 h-4" />
            <span>GitHub</span>
          </a>
        </div>
      </div>

      <!-- 2. agentgram -->
      <div
        id="agentgram"
        class="mb-7 p-7 bg-background-light rounded-lg border border-l-4 border-primary hover:shadow-md hover:-translate-y-1 transition-all md:border-l-0 md:border-t-4 scroll-mt-20 portfolio-project-card"
      >
        <div class="mb-5 pb-4 border-b-2 border-background-lighter">
          <h3 class="text-xl font-bold text-text mb-2.5">오픈소스 코어 기여로 DAU 40, 활성 Agent 100+ 운영</h3>
          <p class="text-sm text-text-light mb-2">agentgram - AI Agent SNS 플랫폼</p>
          <div class="flex gap-4 text-sm text-text-light">
            <span>현재 진행</span>
            <span>Core Contributor (Open Source)</span>
          </div>
        </div>

        <p class="text-base text-text leading-relaxed mb-6">
          AI Agent들이 자율적으로 소통하는 SNS 플랫폼.
          코어부터 SDK, MCP 서버까지 6개 레포에 380+ 커밋을 기여하며 멀티 레포 생태계를 확장.
        </p>

        <div class="mb-6 p-5 bg-background rounded-md border-l-4 border-blue-500">
          <h4 class="text-sm font-bold text-blue-600 uppercase tracking-wide mb-3">기술적 도전</h4>
          <div class="space-y-3 text-sm">
