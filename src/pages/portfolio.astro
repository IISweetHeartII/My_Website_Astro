<!-- Mermaid Script -->
<script>
  import { setupLightModePrintButton } from "@/shared/scripts/light-mode-print";
  import mermaid from "mermaid";

  const token = (name: string, fallback: string): string => {
    const value = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    return value || fallback;
  };

  const initializeMermaid = (): void => {
    try {
      mermaid.initialize({
        startOnLoad: true,
        theme: "base",
        themeVariables: {
          primaryColor: token("--color-primary", "#8b5cf6"),
          primaryTextColor: token("--color-text", "#1a1a2e"),
          primaryBorderColor: token("--color-primary", "#7c3aed"),
          lineColor: token("--color-text-light", "#4a5568"),
          secondaryColor: token("--color-background-lighter", "#f5f3ff"),
          tertiaryColor: token("--color-background-light", "#f9fafb"),
        },
      });
    } catch (error) {
      console.error("Mermaid initialization failed in portfolio page", error);
    }
  };

  const readStoredPageIndex = (): number => {
    try {
      const raw = localStorage.getItem("portfolio:project-page");
      const parsed = Number(raw ?? "0");
      return Number.isFinite(parsed) && parsed >= 0 ? parsed : 0;
    } catch (error) {
      console.warn("Failed to read project page index from storage", error);
      return 0;
    }
  };

  const saveStoredPageIndex = (index: number): void => {
    try {
      localStorage.setItem("portfolio:project-page", String(index));
    } catch (error) {
      console.warn("Failed to save project page index to storage", error);
    }
  };

  const initPortfolioPagination = (): void => {
    const root = document.querySelector<HTMLElement>(".portfolio-root");
    if (!root || root.dataset["paginationInit"] === "true") return;
    root.dataset["paginationInit"] = "true";

    const projectCards = Array.from(root.querySelectorAll<HTMLElement>(".portfolio-project-card"));
    const pageIndicator = document.getElementById("project-page-indicator");
    const prevButton = document.getElementById("prev-project-btn") as HTMLButtonElement | null;
    const nextButton = document.getElementById("next-project-btn") as HTMLButtonElement | null;
    const printButton = document.getElementById("print-portfolio-btn") as HTMLButtonElement | null;

    if (projectCards.length === 0) return;

    const params = new URLSearchParams(window.location.search);
    const queryPage = Number(params.get("p") ?? "1") - 1;
    const initialPage = Number.isFinite(queryPage) && queryPage >= 0 ? queryPage : readStoredPageIndex();
    let currentPage = Math.min(projectCards.length - 1, Math.max(0, initialPage));

    const updatePage = (): void => {
      for (const [index, card] of projectCards.entries()) {
        const active = index === currentPage;
        card.classList.toggle("is-active", active);
        card.hidden = !active;
        card.setAttribute("aria-hidden", String(!active));
      }

      if (pageIndicator) pageIndicator.textContent = `${currentPage + 1} / ${projectCards.length}`;
      if (prevButton) prevButton.disabled = currentPage <= 0;
      if (nextButton) nextButton.disabled = currentPage >= projectCards.length - 1;

      saveStoredPageIndex(currentPage);
      const nextParams = new URLSearchParams(window.location.search);
      nextParams.set("p", String(currentPage + 1));
      window.history.replaceState({}, "", `${window.location.pathname}?${nextParams.toString()}`);
    };

    prevButton?.addEventListener("click", () => {
      currentPage = Math.max(0, currentPage - 1);
      updatePage();
    });

    nextButton?.addEventListener("click", () => {
      currentPage = Math.min(projectCards.length - 1, currentPage + 1);
      updatePage();
    });

    document.addEventListener("keydown", (event: KeyboardEvent) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        currentPage = Math.max(0, currentPage - 1);
        updatePage();
      }

      if (event.key === "ArrowRight") {
        event.preventDefault();
        currentPage = Math.min(projectCards.length - 1, currentPage + 1);
        updatePage();
      }
    });

    setupLightModePrintButton(printButton, {
      beforePrint: () => {
        for (const card of projectCards) {
          card.hidden = false;
          card.classList.add("is-active");
          card.setAttribute("aria-hidden", "false");
        }
      },
      afterPrint: () => {
        updatePage();
      },
    });
    updatePage();
  };

  const setupPortfolioPage = (): void => {
    initializeMermaid();
    initPortfolioPagination();
  };

  document.addEventListener("astro:page-load", setupPortfolioPage);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupPortfolioPage);
  } else {
    setupPortfolioPage();
  }

</script>
