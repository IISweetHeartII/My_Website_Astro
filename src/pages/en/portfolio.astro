---
import { FileText, Github, Mail } from "lucide-astro";
import BreadcrumbSchema from "@/shared/components/seo/BreadcrumbSchema.astro";
import { AUTHOR_EMAIL, AUTHOR_LINKEDIN } from "@/shared/config/consts";
import { ui } from "@/shared/i18n/ui";
import Layout from "../../layouts/Layout.astro";

const projects = [
  {
    id: "agentgram",
    title: "Designed an autonomous delivery pipeline that merged 770 pull requests",
    product: "AgentGram — social infrastructure for autonomous AI agents",
    period: "Ongoing",
    role: "Autonomous pipeline designer and operator",
    summary:
      "I design and operate the autonomous contribution pipeline behind AgentGram. Across the organization, 862 pull requests have been merged; the pipeline produced 770 of those merges. The 770 figure measures system throughput, with authorship distributed across autonomous work and review.",
    challenge:
      "Coordinate useful work across a multi-repository ecosystem without lowering review quality.",
    solution:
      "Built an issue-to-implementation workflow with isolated branches, automated checks, review gates, and maintainership feedback loops.",
    result:
      "770 pipeline-merged pull requests within 862 organization-wide merges; the live network at agentgram.co has 500+ registered agents and 3,400+ posts; agentgram has 31 GitHub stars.",
    ai: [
      "Autonomous issue triage and bounded implementation",
      "Review-driven retries and validation gates",
      "Cross-repository release coordination",
    ],
    tags: ["Next.js 16", "Supabase", "PostgreSQL", "RLS", "OpenAPI", "Docker"],
    href: "https://github.com/agentgram/agentgram",
    linkLabel: "View on GitHub",
  },
  {
    id: "fleet",
    title: "Operating an agent fleet with 41 scheduled jobs and 307 completed kanban cards",
    product: "Hermes Fleet — multi-agent orchestration network",
    period: "Ongoing",
    role: "System designer and operator",
    summary:
      "A Mac mini-based fleet that handles research, content, infrastructure health, code review, and market workflows through explicit ownership and written handoffs.",
    challenge:
      "Keep long-running autonomous work observable, recoverable, and aligned across specialist agents.",
    solution:
      "Combined scheduled jobs, shared kanban state, role boundaries, heartbeat checks, and evidence-gated completion.",
    result: "41 scheduled jobs across the fleet and 307 completed kanban cards.",
    ai: [
      "Document-based agent handoffs",
      "Health checks and scheduled recovery",
      "Human review at high-risk boundaries",
    ],
    tags: ["OpenClaw", "tmux", "Bun", "TypeScript", "Automation"],
  },
  {
    id: "finders",
    title: "Established GCP infrastructure and a code-review culture as Backend Lead",
    product: "Finders — film-lab discovery and booking platform",
    period: "2025.12 — Present",
    role: "Backend Lead (11-person team, 5 backend engineers)",
    summary:
      "Led backend architecture, review standards, and GCP infrastructure for a platform that connects film-camera users with processing labs.",
    challenge:
      "Inconsistent code quality across 5 backend engineers and a constrained infrastructure budget.",
    solution:
      "Documented standards, required pull-request review, used GCP credits, and codified infrastructure with Terraform.",
    result: "Code-review frequency increased 400% (about 5×); recovery time fell from 56h to 5h.",
    ai: [
      "Stable Diffusion inpainting for light-leak restoration",
      "Java 21 Virtual Threads migration with Claude Code",
      "VPC and IAP SSH architecture",
    ],
    tags: ["Java 21", "Spring Boot 3.4", "MySQL", "QueryDSL", "GCP", "Terraform", "Docker"],
    href: "https://github.com/Finders-Official/BE",
    linkLabel: "View backend repository",
  },
  {
    id: "mathfigure",
    title: "Validated a mathematics-content MVP through 40 customer interviews",
    product: "MathFigure — mathematics content authoring SaaS",
    period: "2025.09 — 2025.12",
    role: "Solo full-stack developer, frontend-led",
    summary:
      "Found teachers' core tool-complexity pain point through 40 interviews, then used an I-Corps-based 5-week validation sprint to shape the MVP.",
    challenge:
      "Parse mathematical notation while rendering editable diagrams and graphs in one workflow.",
    solution:
      "Combined MathJSON and Compute Engine with Konva and JSXGraph in an accessible authoring interface.",
    result:
      "Reduced content-production time to 1/10 of the previous workflow and won the ICAN-LABs top award.",
    ai: [
      "MathJSON specification exploration",
      "JSXGraph rendering optimization",
      "Structured synthesis of 40 interview results",
    ],
    tags: ["Next.js", "MathJSON", "Compute Engine", "Konva", "JSXGraph", "Vercel"],
    href: "https://mathfigure.log8.kr",
    linkLabel: "Open the deployed product",
  },
  {
    id: "119-ai",
    title: "Cut emergency hospital-matching calls from 5+ minutes to under 30 seconds",
    product: "119-ai — AI-assisted emergency hospital matching",
    period: "2026",
    role: "Founder / Owner",
    summary:
      "Replaced sequential hospital calls with an AI voice system that can contact 5+ nearby hospitals in parallel from one patient intake.",
    challenge: "Sequential calling creates a dangerous bottleneck during emergency transport.",
    solution:
      "Designed a Twilio parallel-dialing pipeline with Gemini Live API voice conversations and a NestJS/Python backend.",
    result:
      "Matching in under 30 seconds, a tested cost model of KRW 100–200 per case, and the 2026 Cheongryongthon Grand Prize.",
    ai: [
      "Real-time Gemini Live voice conversations",
      "Automated structured call summaries",
      "Parallel Twilio call orchestration",
    ],
    tags: ["NestJS", "Python", "Twilio", "Gemini Live API"],
    href: "https://emergency-ai-call.log8.kr",
    linkLabel: "Open the deployed product",
  },
  {
    id: "duckchinso",
    title: "Built and operates a solo full-stack matchmaking service",
    product: "Duckchinso — a friend-of-Deokhwan matchmaking service",
    period: "2025.11 — Present",
    role: "Solo full-stack developer",
    summary:
      "Turned a growing stream of manual introductions into an operating service with vector similarity matching and AI-generated recommendation reasons.",
    challenge:
      "Securely deploy from a personal Mac mini while replacing a business-registration-dependent notification channel.",
    solution: "Used Cloudflare Tunnel for zero-trust exposure and Solapi SMS for notifications.",
    result: "Live service operation with PortOne payments integrated.",
    ai: [
      "pgvector preference embeddings",
      "Explanations for each recommendation",
      "Automated Docker Compose and certificate operations",
    ],
    tags: [
      "Next.js",
      "Spring Boot",
      "PostgreSQL",
      "pgvector",
      "Docker",
      "Cloudflare Tunnel",
      "PortOne",
    ],
  },
  {
    id: "omechu",
    title: "Improved API response time by 50% through unified JWT authentication",
    product: "Omechu — AI-assisted menu recommendations",
    period: "2025.06 — 2025.08",
    role: "Frontend Developer, authentication owner",
    summary:
      "When mixed cookie-session and JWT logic blocked the team for 2 weeks, I traced backend logs and proposed a unified token architecture beyond my frontend assignment.",
    challenge: "Conflicting authentication paths made behavior unreliable and API responses slow.",
    solution:
      "Unified authentication around JWT and implemented Access/Refresh token lifecycle management.",
    result:
      "Response time improved from 420ms to 210ms (50%); the project won a UMC 8th Demo Day Encouragement Award.",
    ai: [
      "Compared session and JWT tradeoffs",
      "Researched token-management practices",
      "Designed Kakao social-login integration",
    ],
    tags: ["Next.js", "TypeScript", "Node.js", "Zustand", "TanStack Query", "Vercel"],
    href: "https://omechu.log8.kr",
    linkLabel: "Open the deployed product",
  },
  {
    id: "log8",
    title: "Built a bilingual publishing system for human and agent-authored knowledge",
    product: "log8.kr — personal technology publication",
    period: "2024.12 — Present",
    role: "Solo developer and operator",
    summary:
      "An Astro 5 publication workflow that turns reviewed source material into a searchable site while keeping human writing and agent-published research clearly distinguished.",
    challenge:
      "Connect authoring, content collections, migration, SEO, and deployment without a heavy CMS.",
    solution:
      "Built a feature-first Astro architecture, migrated TailwindCSS v3 to v4, and deployed on Cloudflare Pages.",
    result: "60 hand-written blog posts, 100 agent-published Library posts, and 1 guide.",
    ai: [
      "Feature-first refactoring with Claude Code",
      "AST-based TailwindCSS v4 migration",
      "SEO and answer-engine discoverability",
    ],
    tags: ["Astro 5", "TailwindCSS v4", "TypeScript", "Cloudflare Pages", "Bun", "MDX"],
    href: "https://log8.kr",
    linkLabel: "Visit log8.kr",
  },
  {
    id: "starterm",
    title: "Shipped an MVP in 3 weeks and reached 100 weekly active users",
    product: "Starterm — startup terminology learning platform",
    period: "2025.08 — 2025.09",
    role: "Full-Stack Developer (3-person team)",
    summary:
      "A tailored learning platform for students preparing to enter startup programs through a Hanyang University entrepreneurship course.",
    challenge: "Move from MVP scope to real users within a 3-week delivery window.",
    solution:
      "Used Supabase to compress backend work and prioritized the smallest valuable learning flow.",
    result: "Deployed in 3 weeks and reached 100 weekly active users.",
    ai: [
      "Rapid Supabase authentication implementation",
      "Documentation-led Framer Motion optimization",
