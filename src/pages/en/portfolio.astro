const awards = [
  ["Top Award, ICAN-LABS Graduate Entrepreneurship Program", "2025.10"],
  ["Encouragement Award, Tourism AI Competition", "2025.09"],
  ["Encouragement Award, UMC 8th Demo Day", "2025.08"],
  ["Top Award, 2025 Winter Overseas Education Program", "2025.02"],
];

const certifications = [
  ["Engineer Information Processing", "2025.09"],
  ["SQLD (SQL Developer)", "2025.09"],
];
---

<Layout
  title={`Portfolio - ${ui.en.siteTitle}`}
  description="Deokhwan Kim designs and ships human-centered products, AI workflows, and reliable automation systems."
  og_image="/og/page/portfolio.png"
  twitter_image="/og/page/portfolio.png"
  featured_image_alt="Deokhwan Kim portfolio"
  og_type="website"
>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: "Home", url: "/en/" }, { name: "Portfolio", url: "/en/portfolio/" }]} />
  </Fragment>

  <main class="portfolio-root mx-auto max-w-[1600px] bg-background px-6 py-16 print:m-0 print:max-w-full print:bg-white print:p-0">
    <div class="portfolio-extra mb-6 flex flex-col items-start justify-between gap-3 rounded-lg border border-primary/20 bg-primary/10 p-4 sm:flex-row sm:items-center print:hidden">
      <span class="text-sm text-text-light">Need a compact version for a quick review?</span>
      <a href="/en/resume/" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-on-primary transition-colors hover:bg-primary-light">
        <FileText class="h-4 w-4" /> View the résumé (print-ready)
      </a>
    </div>

    <section class="portfolio-controls mb-6 rounded-lg border border-background-lighter bg-background p-4 print:hidden" aria-label="Project pagination">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-text-light">Project</span>
          <button type="button" id="prev-project-btn" class="rounded-md border border-background-lighter bg-background px-3 py-1.5 text-sm font-medium text-text-light">Previous</button>
          <span id="project-page-indicator" class="min-w-[72px] text-center text-xs font-semibold text-text-light">1 / 1</span>
          <button type="button" id="next-project-btn" class="rounded-md border border-background-lighter bg-background px-3 py-1.5 text-sm font-medium text-text-light">Next</button>
        </div>
        <button type="button" id="print-portfolio-btn" class="rounded-md border border-primary bg-primary px-3 py-1.5 text-sm font-semibold text-on-primary">Print / Save PDF</button>
      </div>
    </section>

    <header class="portfolio-extra mb-10 rounded-2xl border border-background-lighter bg-background p-8 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary">Product engineering · AI systems · automation</p>
      <h1 class="mt-3 text-4xl font-extrabold text-text md:text-5xl">Deokhwan Kim</h1>
      <p class="mt-4 max-w-3xl text-xl font-semibold text-primary">I take ambiguous, human problems and turn them into products—and into delivery systems that keep working.</p>
      <p class="mt-4 max-w-3xl leading-relaxed text-text-light">I can own product discovery, full-stack implementation, cloud infrastructure, and AI-assisted operations. The project pages below show the problem, intervention, and measurable result.</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href={`mailto:${AUTHOR_EMAIL}`} class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-3 font-semibold text-on-primary"><Mail class="h-4 w-4" /> Discuss a project</a>
        <a href={AUTHOR_LINKEDIN} target="_blank" rel="noopener noreferrer" class="rounded-xl border border-background-lighter px-5 py-3 font-semibold text-text">LinkedIn</a>
      </div>
    </header>

    <section class="portfolio-extra mb-10 grid gap-4 md:grid-cols-3" aria-label="Selected evidence">
      <div class="rounded-xl border border-background-lighter bg-background p-5"><p class="text-3xl font-extrabold text-primary">770 / 862</p><p class="mt-1 text-sm text-text-light">AgentGram merges from the pipeline I designed and operate / organization-wide merged pull requests</p></div>
      <div class="rounded-xl border border-background-lighter bg-background p-5"><p class="text-3xl font-extrabold text-primary">41 · 307</p><p class="mt-1 text-sm text-text-light">Scheduled fleet jobs · completed kanban cards</p></div>
      <div class="rounded-xl border border-background-lighter bg-background p-5"><p class="text-3xl font-extrabold text-primary">60 · 100 · 1</p><p class="mt-1 text-sm text-text-light">Hand-written blog posts · agent-published Library posts · guide</p></div>
    </section>

    <section id="portfolio-projects-section" class="portfolio-projects-section mb-14 rounded-lg bg-background p-8 shadow-sm">
      <h2 class="mb-6 border-b-2 border-background-lighter pb-3 text-2xl font-bold text-text md:text-3xl">Projects</h2>
      {projects.map((project, index) => (
        <article id={project.id} class:list={["portfolio-project-card scroll-mt-20 rounded-lg border border-l-4 border-primary bg-background-light p-7 md:border-l md:border-t-4", { "is-active": index === 0 }]}>
          <div class="mb-5 border-b-2 border-background-lighter pb-4">
            <h3 class="mb-2.5 text-xl font-bold text-text">{project.title}</h3>
            <p class="mb-2 text-sm text-text-light">{project.product}</p>
            <div class="flex flex-wrap gap-4 text-sm text-text-light"><span>{project.period}</span><span>{project.role}</span></div>
          </div>
          <p class="mb-6 text-base leading-relaxed text-text">{project.summary}</p>
          <div class="mb-6 rounded-md border-l-4 border-blue-500 bg-background p-5">
            <h4 class="mb-3 text-sm font-bold uppercase tracking-wide text-blue-600">Product and technical challenge</h4>
            <div class="space-y-3 text-sm">
              <p><strong class="text-text">Problem:</strong> <span class="text-text-light">{project.challenge}</span></p>
              <p><strong class="text-text">Approach:</strong> <span class="text-text-light">{project.solution}</span></p>
              <p><strong class="text-text">Result:</strong> <span class="text-text-light">{project.result}</span></p>
            </div>
          </div>
          <div class="mb-6 rounded-md border-l-4 border-emerald-500 bg-background-light p-5">
            <h4 class="mb-3 text-sm font-bold uppercase tracking-wide text-emerald-600">AI leverage</h4>
            <ul class="list-inside list-disc space-y-2 text-sm text-text">{project.ai.map((item) => <li>{item}</li>)}</ul>
          </div>
          <div class="mb-6 flex flex-wrap gap-2">{project.tags.map((tag) => <span class="rounded-full bg-primary px-3.5 py-1.5 text-xs font-semibold text-on-primary">{tag}</span>)}</div>
          {project.href && <div class="mt-5 border-t-2 border-background-lighter pt-5"><a href={project.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-md bg-text px-4 py-2.5 text-sm font-semibold text-on-primary"><Github class="h-4 w-4" /> {project.linkLabel}</a></div>}
        </article>
      ))}
    </section>

    <section class="portfolio-extra mb-10 grid gap-6 lg:grid-cols-2">
      <div class="rounded-xl border border-background-lighter bg-background p-6">
        <h2 class="text-2xl font-bold text-text">Experience</h2>
        <div class="mt-5 space-y-5 text-sm text-text-light">
          <div><div class="flex justify-between gap-4"><h3 class="font-bold text-text">UMC 8th / 9th Cohort, Web Part</h3><span>2025.03 — Present</span></div><p>9th-cohort Web Part Lead and Spring Boot challenger; supported members' learning and reviewed code. In the 8th cohort, owned authentication for Omechu.</p></div>
          <div><div class="flex justify-between gap-4"><h3 class="font-bold text-text">Banpo 4-dong Catholic Church, Youth Teacher</h3><span>2019.09 — 2024.12</span></div><p>Led catechism programs for 30 middle-school students, developing practical communication and empathy.</p></div>
          <div><div class="flex justify-between gap-4"><h3 class="font-bold text-text">Practical AI Lectures</h3><span>2025.05, 07, 09</span></div><p>Delivered 3 sessions for senior small-business owners and founders on ChatGPT, Gemini Gems, NotebookLM, MCP, and agent AI.</p></div>
        </div>
      </div>
      <div class="rounded-xl border border-background-lighter bg-background p-6">
        <h2 class="text-2xl font-bold text-text">Education</h2>
        <div class="mt-5 flex justify-between gap-4"><h3 class="font-bold text-text">Chung-Ang University</h3><span class="text-sm text-text-light">2020.03 — 2026.02 (expected)</span></div>
        <p class="mt-2 text-sm font-semibold text-text-light">Mathematics</p>
        <p class="mt-2 text-sm leading-relaxed text-text-light">Applying mathematical reasoning and structured problem solving to product development. Completing 16 credits in the final semester, with graduation expected in February 2026.</p>
        <p class="mt-5 text-sm text-text-light">GitHub evidence: agentgram <strong class="text-text">31 stars</strong>; ax-score <strong class="text-text">3 stars</strong>.</p>
      </div>
    </section>

    <section class="portfolio-extra grid gap-6 md:grid-cols-2">
      <div class="rounded-xl border border-background-lighter bg-background p-6"><h2 class="text-xl font-bold text-text">Awards</h2><ul class="mt-4 space-y-2 text-sm text-text-light">{awards.map(([name, date]) => <li class="flex justify-between gap-4"><span>{name}</span><span>{date}</span></li>)}</ul></div>
      <div class="rounded-xl border border-background-lighter bg-background p-6"><h2 class="text-xl font-bold text-text">Certifications</h2><ul class="mt-4 space-y-2 text-sm text-text-light">{certifications.map(([name, date]) => <li class="flex justify-between gap-4"><span>{name}</span><span>{date}</span></li>)}</ul></div>
    </section>
  </main>
</Layout>

<style>
  /* Screen-visible overview blocks opt in because the A4 project viewer hides other direct children. */
  .portfolio-root > :not(.portfolio-controls):not(#portfolio-projects-section):not(.portfolio-extra) { display: none; }
  .portfolio-project-card { display: none; margin: 0 auto; width: min(100%, 210mm); min-height: 297mm; height: 297mm; overflow-y: auto; background: var(--color-background); border-top-width: 4px; border-top-color: var(--color-primary); box-shadow: 0 22px 38px -28px rgb(15 23 42 / 0.42); font-size: 0.875rem; line-height: 1.45; }
  .portfolio-project-card.is-active { display: block; }
  #portfolio-projects-section { padding: 0; background: transparent; border: 0; box-shadow: none; margin-bottom: 0; }
  #portfolio-projects-section > h2 { display: none; }
  .portfolio-project-card h3 { font-size: 1rem !important; line-height: 1.5 !important; }
  .portfolio-project-card h4 { font-size: 0.8rem !important; line-height: 1.4 !important; }
  .portfolio-project-card p, .portfolio-project-card li, .portfolio-project-card span { font-size: 0.875rem !important; line-height: 1.5 !important; }
  @media (max-width: 1024px) { .portfolio-project-card { width: 100%; min-height: auto; height: auto; overflow: visible; } }
  @media print {
    @page { size: A4; margin: 0; }
    :global(header), :global(footer), :global(nav), :global([class*="ProgressIndicator"]), :global([class*="progress"]) { display: none !important; }
    :global(html), :global(body), :global(body > main), :global(main.grow) { margin: 0 !important; padding: 0 !important; background: white !important; }
    html { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    .portfolio-controls { display: none !important; }
    .portfolio-root { max-width: 100% !important; padding: 0 !important; margin: 0 !important; background: white !important; }
    .portfolio-root > :not(#portfolio-projects-section) { display: none !important; }
    #portfolio-projects-section { padding: 0 !important; margin: 0 !important; background: white !important; }
    .portfolio-project-card { display: block !important; width: 100% !important; height: 297mm !important; box-sizing: border-box !important; overflow: hidden !important; break-after: page; page-break-after: always; break-inside: avoid; margin: 0 !important; padding: 15mm 15mm 12mm !important; border: 0 !important; border-radius: 0 !important; box-shadow: none !important; background: white !important; }
    .portfolio-project-card:last-child { break-after: auto; page-break-after: auto; }
    .portfolio-project-card h3 { margin-bottom: 0.25rem !important; }
    .portfolio-project-card h4 { margin-bottom: 0.2rem !important; }
    .portfolio-project-card p, .portfolio-project-card li, .portfolio-project-card span { font-size: 0.8rem !important; line-height: 1.45 !important; }
    .portfolio-project-card .mb-6 { margin-bottom: 0.4rem !important; }
    .portfolio-project-card .mb-5 { margin-bottom: 0.35rem !important; }
    .portfolio-project-card .p-5 { padding: 0.35rem !important; }
    .portfolio-project-card > .mt-5.pt-5 { display: none !important; }
    .portfolio-project-card .rounded-full { background-color: #8b5cf6 !important; color: white !important; }
  }
</style>

<script>
  import { setupLightModePrintButton } from "@/shared/scripts/light-mode-print";

  const initPortfolioPagination = (): void => {
    const root = document.querySelector<HTMLElement>(".portfolio-root");
    if (!root || root.dataset["paginationInit"] === "true") return;
    root.dataset["paginationInit"] = "true";
    const projectCards = Array.from(root.querySelectorAll<HTMLElement>(".portfolio-project-card"));
    const pageIndicator = document.getElementById("project-page-indicator");
    const prevButton = document.getElementById("prev-project-btn") as HTMLButtonElement | null;
    const nextButton = document.getElementById("next-project-btn") as HTMLButtonElement | null;
    const printButton = document.getElementById("print-portfolio-btn") as HTMLButtonElement | null;
    if (projectCards.length === 0) return;
    const queryPage = Number(new URLSearchParams(window.location.search).get("p") ?? "1") - 1;
    let currentPage = Number.isFinite(queryPage) ? Math.min(projectCards.length - 1, Math.max(0, queryPage)) : 0;
    const updatePage = (): void => {
      projectCards.forEach((card, index) => { const active = index === currentPage; card.classList.toggle("is-active", active); card.hidden = !active; card.setAttribute("aria-hidden", String(!active)); });
      if (pageIndicator) pageIndicator.textContent = `${currentPage + 1} / ${projectCards.length}`;
      if (prevButton) prevButton.disabled = currentPage === 0;
      if (nextButton) nextButton.disabled = currentPage === projectCards.length - 1;
      const params = new URLSearchParams(window.location.search); params.set("p", String(currentPage + 1)); window.history.replaceState({}, "", `${window.location.pathname}?${params}`);
    };
    prevButton?.addEventListener("click", () => { currentPage = Math.max(0, currentPage - 1); updatePage(); });
    nextButton?.addEventListener("click", () => { currentPage = Math.min(projectCards.length - 1, currentPage + 1); updatePage(); });
    document.addEventListener("keydown", (event) => { if (event.key === "ArrowLeft") { currentPage = Math.max(0, currentPage - 1); updatePage(); } else if (event.key === "ArrowRight") { currentPage = Math.min(projectCards.length - 1, currentPage + 1); updatePage(); } });
    setupLightModePrintButton(printButton, { beforePrint: () => projectCards.forEach((card) => { card.hidden = false; card.classList.add("is-active"); }), afterPrint: updatePage });
    updatePage();
  };
  document.addEventListener("astro:page-load", initPortfolioPagination);
  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", initPortfolioPagination); else initPortfolioPagination();
</script>
