---
import { getCollection } from "astro:content";
import BlogCard from "@/features/blog/components/BlogCard.astro";
import LibraryCard from "@/features/library/components/LibraryCard.astro";
import Layout from "@/layouts/Layout.astro";
import { getEntrySlug, isPublishedInLocale } from "@/shared/i18n/ui";
import { getLatestPosts, transformPostForCard } from "@/shared/utils/blog";

const blogPosts = (await getCollection("blog")).filter((post) => isPublishedInLocale(post, "en"));
const latestBlogPosts = getLatestPosts(blogPosts, 4).map((post) => transformPostForCard(post));
const libraryPosts = (await getCollection("library"))
  .filter((post) => isPublishedInLocale(post, "en"))
  .sort((a, b) => (b.data.created_date?.getTime() ?? 0) - (a.data.created_date?.getTime() ?? 0))
  .slice(0, 3);
---

<Layout title="Log8 in English" description="Selected English translations from Log8." og_type="website">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-12 p-6 md:p-8">
    <section class="rounded-3xl border border-background-lighter bg-background p-8 shadow-sm md:p-10">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">Log8 English</p>
      <h1 class="mt-3 text-4xl font-extrabold text-text md:text-5xl">Selected translations</h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-text-light">
        English versions are published only when a real reviewed translation exists. Korean URLs stay unchanged.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/en/blog/" class="rounded-xl bg-primary px-5 py-3 font-semibold text-on-primary transition-colors hover:bg-accent">Read the blog</a>
        <a href="/en/library/" class="rounded-xl border border-background-lighter px-5 py-3 font-semibold text-text transition-colors hover:border-primary/20 hover:text-primary">Browse Library</a>
      </div>
    </section>

    <section>
      <div class="mb-5 flex items-end justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">Blog</p>
          <h2 class="mt-2 text-2xl font-bold text-text">Latest posts</h2>
        </div>
        <a href="/en/blog/" class="text-sm font-semibold text-primary hover:text-accent">View all</a>
      </div>
      {latestBlogPosts.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          {latestBlogPosts.map((post) => <BlogCard {...post} locale="en" />)}
        </div>
      ) : (
        <p class="rounded-2xl border border-background-lighter bg-background p-6 text-text-muted">No English blog posts yet.</p>
      )}
    </section>

    <section>
      <div class="mb-5 flex items-end justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent/80">Library</p>
          <h2 class="mt-2 text-2xl font-bold text-text">Latest Library notes</h2>
        </div>
        <a href="/en/library/" class="text-sm font-semibold text-primary hover:text-accent">View all</a>
      </div>
      {libraryPosts.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {libraryPosts.map((post) => <LibraryCard title={post.data.title} description={post.data.description ?? undefined} date={post.data.created_date ?? undefined} slug={getEntrySlug(post)} featuredImage={post.data.featured_image ?? undefined} featuredImageAlt={post.data.featured_image_alt ?? undefined} category={post.data.category} agent={post.data.agent ?? undefined} readingTime={post.data.reading_time ?? undefined} tags={post.data.tags ?? undefined} locale="en" />)}
        </div>
      ) : (
        <p class="rounded-2xl border border-background-lighter bg-background p-6 text-text-muted">No English library posts yet.</p>
      )}
    </section>
  </div>
</Layout>
