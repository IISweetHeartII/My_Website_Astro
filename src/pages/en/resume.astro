---
import { ExternalLink, FileDown } from "lucide-astro";
import BreadcrumbSchema from "@/shared/components/seo/BreadcrumbSchema.astro";
import { SITE_TITLE } from "@/shared/config/consts";
import Layout from "../../layouts/Layout.astro";

interface ProofItem {
  id: string;
  label: string;
  date: string;
  image: string;
}

const awards: ProofItem[] = [
  {
    id: "finders-demoday",
    label: "Top Award, UMC 9th Demo Day (Finders)",
    date: "2026.02",
    image: "/images/awards/finders-demoday.jpg",
  },
  {
    id: "cheongryong-hackathon",
    label: "Grand Prize, 2026 Cheongryongthon (119-ai)",
    date: "2026.02",
    image: "/images/awards/cheongryong-hackathon.jpg",
  },
  {
    id: "umc9-hackathon",
    label: "Grand Prize, UMC 9th Hackathon (Happy Diary)",
    date: "2026.01",
    image: "/images/awards/umc9-hackathon.jpg",
  },
  {
    id: "ican-labs",
    label: "Top Award, ICAN-LABs Entrepreneurship Exploration Program",
    date: "2025.11",
    image: "/images/awards/ican-labs.jpg",
  },
  {
    id: "umc8-demoday",
    label: "Encouragement Award, UMC 8th Demo Day (Omechu)",
    date: "2025.08",
    image: "/images/awards/umc8-demoday.jpg",
  },
  {
    id: "overseas-education",
    label: "Top Award, Entrepreneurship Overseas Education Program",
    date: "2025.02",
    image: "/images/awards/overseas-education.jpg",
  },
];

const certifications: ProofItem[] = [
  {
    id: "engineer-info",
    label: "Engineer Information Processing",
    date: "2025.09",
    image: "/images/awards/engineer-info.png",
  },
  { id: "sqld", label: "SQLD", date: "2025.09", image: "/images/awards/sqld.png" },
  { id: "opic-ih", label: "OPIc IH", date: "2024.12", image: "/images/awards/opic-ih.pdf" },
];
---

<Layout
  title={`Resume - ${SITE_TITLE}`}
  description="Deokhwan Kim — product engineer and resourceful problem solver building human-centered AI products."
  og_image="/og/page/resume.png"
  twitter_image="/og/page/resume.png"
  featured_image_alt="Deokhwan Kim résumé"
  og_type="website"
>
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ name: "Home", url: "/en/" }, { name: "Résumé", url: "/en/resume/" }]} />
  </Fragment>

  <div class="resume-wrapper mx-auto max-w-[1600px] bg-background px-6 py-16 print:m-0 print:max-w-full print:bg-white print:p-0">
    <div class="resume-shell">
      <div class="resume-main">
        <article class="a4-page mx-auto min-h-[297mm] w-[210mm] border border-background-lighter bg-background-light px-12 py-8 shadow-lg max-md:min-h-0 max-md:w-full print:m-0 print:min-h-0 print:w-full print:border-0 print:px-[15mm] print:pb-[12mm] print:pt-[15mm] print:shadow-none">
          <div class="mb-6 flex items-center justify-between print:hidden">
            <a href="/en/portfolio/" class="flex items-center gap-1 text-sm font-medium text-primary hover:text-primary-light"><ExternalLink class="h-4 w-4" /> View detailed portfolio</a>
            <button id="print-btn" class="flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-semibold text-on-primary transition-colors hover:bg-primary-light"><FileDown class="h-4 w-4" /> Print / Save PDF</button>
          </div>

          <header class="mb-4 flex items-start justify-between border-b-2 border-primary-light border-l-4 border-l-primary pb-4 pl-4">
            <div><h1 class="mb-1 text-3xl font-bold text-text">Deokhwan Kim</h1><p class="text-lg font-semibold text-primary">Resourceful problem solver · Product engineer</p></div>
            <div class="space-y-0.5 text-right text-sm text-text-light"><p>sachi009955@gmail.com</p><p>github.com/IISweetHeartII</p><p>log8.kr</p></div>
          </header>

          <section class="mb-4">
            <h2 class="mb-2 border-b border-background-lighter pb-1 text-lg font-bold text-primary">What I can take on</h2>
            <div class="space-y-1 text-sm text-text-light">
              <p><strong class="font-semibold text-text">I turn ambiguous customer problems into working AI products and reliable delivery systems.</strong></p>
              <ul class="list-disc space-y-0.5 pl-4">
                <li>Product discovery, customer interviews, MVP scope, and full-stack implementation.</li>
                <li>Cloud infrastructure, deployment, observability, recovery, and code-review systems.</li>
                <li>Agent orchestration with explicit ownership, validation gates, and human review boundaries.</li>
              </ul>
            </div>
          </section>

          <section class="mb-4">
            <h2 class="mb-2 border-b border-background-lighter pb-1 text-lg font-bold text-primary">Selected evidence</h2>
            <ul class="grid grid-cols-2 gap-x-6 gap-y-1 pl-4 text-sm text-text-light list-disc evidence-grid">
              <li>AgentGram: <strong class="text-text">862 organization-wide merged pull requests</strong>; <strong class="text-text">770</strong> were merged by the autonomous pipeline I designed and operate. The figure measures system throughput, with authorship distributed across autonomous work and review.</li>
              <li>Fleet operations: <strong class="text-text">41 scheduled jobs</strong> and <strong class="text-text">307 completed kanban cards</strong>.</li>
              <li>log8.kr: <strong class="text-text">60 hand-written blog posts</strong>, <strong class="text-text">100 agent-published Library posts</strong>, and <strong class="text-text">1 guide</strong>.</li>
              <li>GitHub stars: <strong class="text-text">agentgram 31</strong> and <strong class="text-text">ax-score 3</strong>.</li>
            </ul>
          </section>

          <section class="mb-4">
            <h2 class="mb-3 border-b border-background-lighter pb-1 text-lg font-bold text-primary">Projects</h2>
            <div class="project-card mb-5">
              <div class="mb-1.5"><h3 class="text-base font-bold text-primary-light"><a href="https://finders.it.kr" target="_blank" rel="noopener noreferrer">Built GCP infrastructure and established team code review as Backend Lead</a></h3><span class="text-sm text-text-muted">2025.12 — Present | Backend Lead (5-person backend team)</span></div>
              <div class="project-grid grid grid-cols-2 gap-x-6 text-sm">
                <ul class="list-disc space-y-0.5 pl-4 text-text-light"><li>Raised review frequency <strong class="text-text">400% (about 5×)</strong>.</li><li>Reduced Terraform-based recovery from <strong class="text-text">56h to 5h</strong>.</li><li>Scripted the rebuild path for an estimated <strong class="text-text">about 2h</strong> next lead time.</li></ul>
                <ul class="list-disc space-y-0.5 pl-4 text-text-light"><li><strong class="text-text">Java 21, Spring Boot 3.4</strong>, MySQL, QueryDSL.</li><li><strong class="text-text">Terraform + GCP</strong> infrastructure as code.</li><li>CI/CD, VPC, separated dev/prod databases, rollback deployment.</li></ul>
              </div>
            </div>

            <div class="project-card mb-5">
              <div class="mb-1.5"><h3 class="text-base font-bold text-primary-light"><a href="https://github.com/agentgram/agentgram" target="_blank" rel="noopener noreferrer">Designed and operates AgentGram's autonomous contribution pipeline</a></h3><span class="text-sm text-text-muted">Ongoing | Pipeline designer and operator</span></div>
              <div class="project-grid grid grid-cols-2 gap-x-6 text-sm">
                <ul class="list-disc space-y-0.5 pl-4 text-text-light"><li><strong class="text-text">770 pipeline merges</strong> within <strong class="text-text">862 organization-wide merges</strong>.</li><li>Review-gated autonomous work across a multi-repository ecosystem.</li><li>The metric describes autonomous-system throughput with distributed authorship.</li></ul>
                <ul class="list-disc space-y-0.5 pl-4 text-text-light"><li><strong class="text-text">Next.js 16</strong>, TailwindCSS v4.</li><li><strong class="text-text">Supabase (PostgreSQL + RLS)</strong>, API-first architecture.</li><li>Self-hosting, Docker, REST API, OpenAPI.</li></ul>
              </div>
            </div>

            <div class="project-card mb-5">
              <div class="mb-1.5"><h3 class="text-base font-bold text-primary-light"><a href="https://mathfigure.log8.kr" target="_blank" rel="noopener noreferrer">Won the ICAN-LABs top award with a 40-interview MVP</a></h3><span class="text-sm text-text-muted">2025.09 — 2025.12 | Solo full-stack developer, frontend-led</span></div>
              <div class="project-grid grid grid-cols-2 gap-x-6 text-sm">
                <ul class="list-disc space-y-0.5 pl-4 text-text-light"><li>Cut mathematics-content production time to <strong class="text-text">1/10</strong>.</li><li>Identified tool complexity through <strong class="text-text">40 interviews</strong>.</li><li>Used a <strong class="text-text">5-week</strong> I-Corps-based validation sprint.</li></ul>
                <ul class="list-disc space-y-0.5 pl-4 text-text-light"><li>Next.js, MathJSON, Fabric.js, JSXGraph.</li><li>Formula parsing and geometry visualization engine.</li><li>MVP prototyping and user testing.</li></ul>
              </div>
            </div>

            <div class="project-card mb-4">
              <div class="mb-1.5"><h3 class="text-base font-bold text-primary-light"><a href="https://emergency-ai-call.log8.kr" target="_blank" rel="noopener noreferrer">119-ai: parallel AI calls for emergency hospital matching</a></h3><span class="text-sm text-text-muted">2026 | Founder / Owner</span></div>
              <div class="project-grid grid grid-cols-2 gap-x-6 text-sm">
                <ul class="list-disc space-y-0.5 pl-4 text-text-light"><li>Calls <strong class="text-text">5+ hospitals</strong> in parallel from one intake.</li><li>Reduced a <strong class="text-text">5+ minute</strong> sequence to <strong class="text-text">under 30 seconds</strong>.</li><li>Won the 2026 Cheongryongthon Grand Prize.</li></ul>
                <ul class="list-disc space-y-0.5 pl-4 text-text-light"><li>Twilio + Gemini Live API voice automation.</li><li>NestJS + Python AI call pipeline.</li><li>Validated a <strong class="text-text">KRW 100–200</strong> per-case cost model.</li></ul>
              </div>
            </div>
          </section>

          <div class="hidden print:block print:break-before-page"></div>

          <section class="mb-4 print:pt-[15mm]">
            <h2 class="mb-2 border-b border-background-lighter pb-1 text-lg font-bold text-primary">Tech Stack</h2>
            <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
              <p><strong class="inline-block w-20 text-text">Languages</strong><span class="text-text-light">TypeScript, Java, Python, C++</span></p>
              <p><strong class="inline-block w-20 text-text">Frontend</strong><span class="text-text-light">Next.js, Astro, React, TailwindCSS</span></p>
              <p><strong class="inline-block w-20 text-text">Backend</strong><span class="text-text-light">Spring Boot, NestJS, Supabase</span></p>
              <p><strong class="inline-block w-20 text-text">Database</strong><span class="text-text-light">PostgreSQL, MySQL, pgvector</span></p>
              <p class="col-span-2"><strong class="inline-block w-20 text-text">DevOps</strong><span class="text-text-light">GCP, Docker, Cloudflare Tunnel, GitHub Actions, Sentry, tmux</span></p>
            </div>
          </section>

          <section class="mb-4">
            <h2 class="mb-2 border-b border-background-lighter pb-1 text-lg font-bold text-primary">AI Orchestration Lab</h2>
            <ul class="list-disc space-y-1 pl-4 text-sm text-text-light">
              <li>Operates multi-agent orchestration with Antigravity, Claude Code Team (tmux), and OMO.</li>
              <li>Measured <strong class="text-text">3× learning efficiency</strong>, <strong class="text-text">7× development speed</strong>, and <strong class="text-text">7× structural design quality</strong> after the workflow shift.</li>
              <li>Rosie (OpenClaw): Mac mini 24/7 operations, heartbeat/cron, social, E2E, and Google Workspace automation.</li>
              <li>Dave (OpenClaw): desktop-start integration, E2E, and feature viability/profitability review.</li>
            </ul>
          </section>

          <section class="mb-4">
            <h2 class="mb-2 border-b border-background-lighter pb-1 text-lg font-bold text-primary">Experience</h2>
            <div class="space-y-1.5 text-sm text-text-light">
              <div class="flex justify-between gap-4"><p><strong class="text-text">UMC 9th Cohort</strong> — Web Part Lead (teaching and mentoring), Spring Boot challenger</p><span>2025.09 — Present</span></div>
              <div class="flex justify-between gap-4"><p><strong class="text-text">UMC 8th Cohort</strong> — Web challenger (React, Next.js)</p><span>2025.03 — 2025.08</span></div>
              <div class="flex justify-between gap-4"><p><strong class="text-text">Practical AI lectures</strong> — senior small-business owners</p><span>2025.05, 07</span></div>
              <div class="flex justify-between gap-4"><p><strong class="text-text">Practical AI lecture</strong> — Re:ium founders (MCP, agent AI)</p><span>2025.09</span></div>
            </div>
          </section>

          <section class="mb-4">
            <h2 class="mb-2 border-b border-background-lighter pb-1 text-lg font-bold text-primary">Awards & Certifications</h2>
            <div class="grid grid-cols-[3fr_2fr] gap-x-4 text-sm">
              <div><p class="mb-1 font-semibold text-text-light">Awards</p><ul class="list-disc space-y-0.5 pl-4 text-text-light">{awards.map((award) => <li><button type="button" data-proof-id={award.id} data-proof-image={award.image} data-proof-title={award.label} data-proof-date={award.date} aria-controls="proof-panel" aria-expanded="false" class="proof-item w-full cursor-pointer rounded px-1 py-0.5 text-left">{award.label} ({award.date})</button></li>)}</ul></div>
              <div><p class="mb-1 font-semibold text-text-light">Certifications</p><ul class="list-disc space-y-0.5 pl-4 text-text-light">{certifications.map((certification) => <li><button type="button" data-proof-id={certification.id} data-proof-image={certification.image} data-proof-title={certification.label} data-proof-date={certification.date} aria-controls="proof-panel" aria-expanded="false" class="proof-item w-full cursor-pointer rounded px-1 py-0.5 text-left">{certification.label} ({certification.date})</button></li>)}</ul></div>
            </div>
          </section>

          <section>
            <h2 class="mb-2 border-b border-background-lighter pb-1 text-lg font-bold text-primary">Education</h2>
            <div class="text-sm"><div class="mb-1 flex justify-between gap-4"><strong class="text-text">Chung-Ang University</strong><span class="text-text-muted">2020.03 — 2026.02 (expected graduation)</span></div><ul class="list-disc space-y-0.5 pl-4 text-text-light"><li>Mathematics (primary major) / Software & Humanities Convergence (double major).</li><li>Completed the teaching curriculum (expected Level 2 Secondary School Teacher Certificate).</li><li>162 credits completed; GPA 3.86/4.5.</li></ul></div>
          </section>
        </article>
        <p class="mt-4 text-center text-sm text-text-muted print:hidden">Two-page A4 preview · optimized automatically for print</p>
      </div>

      <div id="proof-panel-slot" class="proof-panel-slot print:hidden" aria-hidden="true">
        <aside id="proof-panel" class="proof-panel" aria-hidden="true" role="dialog" aria-label="Award or certification evidence">
          <div class="flex items-center justify-between border-b border-background-lighter bg-background-light px-6 py-4"><h3 id="proof-panel-title" class="truncate pr-4 text-base font-bold text-text"></h3><button id="proof-panel-close" class="h-9 w-9 rounded-lg text-text-light" aria-label="Close evidence panel">×</button></div>
          <div class="px-6 py-6"><div class="mb-4 flex min-h-[280px] items-center justify-center overflow-hidden rounded-lg border border-background-lighter bg-background-light"><img id="proof-panel-image" src="" alt="" class="hidden max-h-[58vh] h-auto w-full object-contain" /><iframe id="proof-panel-document" src="" title="Evidence document" class="hidden h-[480px] w-full bg-white"></iframe><div id="proof-panel-loading" class="py-12 text-sm text-text-muted">Loading evidence…</div></div><p id="proof-panel-date" class="mb-4 text-sm text-text-muted"></p><a id="proof-panel-download" href="" download class="flex w-full justify-center rounded-md bg-primary px-4 py-2.5 text-sm font-semibold text-on-primary">Download evidence</a></div>
        </aside>
      </div>
    </div>
  </div>
</Layout>

<style>
  .resume-shell { display: flex; align-items: flex-start; justify-content: center; gap: 1.5rem; }
  .resume-main { flex: 0 0 auto; }
  .proof-panel-slot { width: 0; flex: 0 0 auto; overflow: hidden; transition: width 320ms ease; }
  .proof-panel-slot.is-open { width: 620px; }
  .proof-panel { width: 620px; max-width: 620px; border: 1px solid var(--color-background-lighter); border-radius: 0.75rem; background: var(--color-background-light); box-shadow: 0 20px 32px -18px rgb(0 0 0 / 0.35); opacity: 0; transform: translateX(24px); transition: opacity 240ms ease, transform 320ms ease; }
  .proof-panel-slot.is-open .proof-panel { opacity: 1; transform: translateX(0); }
  .proof-panel[aria-hidden="true"] { pointer-events: none; }
  .proof-item { border: 0; background: transparent; font: inherit; }
  .proof-item.proof-item-active { color: var(--color-primary); background: color-mix(in srgb, var(--color-primary) 10%, transparent); font-weight: 600; }
  @media (max-width: 1200px) { .resume-shell { display: block; } .proof-panel-slot, .proof-panel-slot.is-open { width: 100%; } .proof-panel-slot:not(.is-open) { display: none; } .proof-panel { width: 100%; max-width: 100%; margin-top: 1rem; } }
  @media (max-width: 760px) { .project-grid, .evidence-grid { grid-template-columns: 1fr; } }
  @media print {
    @page { size: A4; margin: 0; }
    :global(header), :global(footer), :global(nav), :global([class*="ProgressIndicator"]), :global([class*="progress"]) { display: none !important; }
    :global(html), :global(body), :global(body > main), :global(main.grow) { margin: 0 !important; padding: 0 !important; background: white !important; }
    html { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    .a4-page { background: white !important; word-break: keep-all; line-break: strict; }
    .a4-page h2[class*="border-b"] { border-bottom-color: #475569 !important; border-bottom-width: 1.5px !important; }
    .resume-wrapper { background: white !important; }
    .resume-shell { display: block !important; }
    .proof-panel-slot, .proof-panel { display: none !important; }
    .proof-item { cursor: default !important; }
  }
</style>

<script>
  import { setupLightModePrintButton } from "@/shared/scripts/light-mode-print";

  const setupResume = (): void => {
    const panel = document.getElementById("proof-panel");
    const slot = document.getElementById("proof-panel-slot");
    const title = document.getElementById("proof-panel-title");
    const image = document.getElementById("proof-panel-image") as HTMLImageElement | null;
    const documentFrame = document.getElementById("proof-panel-document") as HTMLIFrameElement | null;
    const loading = document.getElementById("proof-panel-loading");
    const date = document.getElementById("proof-panel-date");
    const download = document.getElementById("proof-panel-download") as HTMLAnchorElement | null;
    const close = document.getElementById("proof-panel-close");
    const items = document.querySelectorAll<HTMLElement>("[data-proof-id]");
    if (!panel || !slot || !title || !image || !documentFrame || !close) return;
    const closePanel = (): void => { slot.classList.remove("is-open"); slot.setAttribute("aria-hidden", "true"); panel.setAttribute("aria-hidden", "true"); items.forEach((item) => { item.classList.remove("proof-item-active"); item.setAttribute("aria-expanded", "false"); }); };
    items.forEach((item) => item.addEventListener("click", () => {
      const source = item.dataset["proofImage"] ?? ""; const label = item.dataset["proofTitle"] ?? ""; const isPdf = source.toLowerCase().endsWith(".pdf");
      title.textContent = label; if (date) date.textContent = item.dataset["proofDate"] ?? ""; if (download) download.href = source;
      image.classList.toggle("hidden", isPdf); documentFrame.classList.toggle("hidden", !isPdf); if (loading) loading.classList.add("hidden");
      if (isPdf) documentFrame.src = source; else { image.src = source; image.alt = `${label} evidence`; }
      slot.classList.add("is-open"); slot.setAttribute("aria-hidden", "false"); panel.setAttribute("aria-hidden", "false"); items.forEach((candidate) => { const active = candidate === item; candidate.classList.toggle("proof-item-active", active); candidate.setAttribute("aria-expanded", String(active)); });
    }));
    close.addEventListener("click", closePanel);
    document.addEventListener("keydown", (event) => { if (event.key === "Escape") closePanel(); });
    setupLightModePrintButton(document.getElementById("print-btn") as HTMLButtonElement | null);
  };
  document.addEventListener("astro:page-load", setupResume);
  if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", setupResume); else setupResume();
</script>
