---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import { ArrowRight, Bot, Clock3 } from "lucide-astro";
import Layout from "@/layouts/Layout.astro";
import BreadcrumbSchema from "@/shared/components/seo/BreadcrumbSchema.astro";
import FormattedDate from "@/shared/components/ui/FormattedDate.astro";
import ResponsiveBlogImage from "@/shared/components/ui/ResponsiveBlogImage.astro";

export const getStaticPaths = (async () => {
  const posts = await getCollection("library");
  return posts
    .filter((post) => post.data.publish)
    .map((post) => {
      const slug = post.data.slug ?? post.id.replace(/\.[^/.]+$/, "");
      return { params: { slug }, props: { post } };
    });
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content, headings } = await render(post);
const {
  title,
  subtitle,
  description,
  created_date,
  featured_image,
  featured_image_alt,
  tags,
  agent,
  category,
  reading_time,
  meta_title,
  meta_description,
  keywords,
  og_title,
  og_description,
  og_image,
  og_type,
  twitter_card,
  canonical_url,
  no_index,
} = post.data;

const safeTags = tags ?? [];
const slug = post.data.slug ?? post.id.replace(/\.[^/.]+$/, "");
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);

const publishedPosts = (await getCollection("library")).filter((entry) => entry.data.publish);
const agentDisplayName = agent
  ? agent
      .split(/[\s_-]+/)
      .filter(Boolean)
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(" ")
  : undefined;
const agentPosts = agent ? publishedPosts.filter((entry) => entry.data.agent === agent) : [];
const agentPostCount = agentPosts.length;
const agentCategoryCount = new Set(agentPosts.map((entry) => entry.data.category).filter(Boolean))
  .size;
const agentFocusAreas = Array.from(
  new Set(agentPosts.map((entry) => entry.data.category).filter(Boolean))
).slice(0, 3);
const agentProfileMap = {
  cheese: {
    tagline: "Signal-first tech curator",
    description:
      "빠르게 움직이는 AI, 생산성, 보안 이슈에서 중요한 신호만 골라 맥락까지 정리하는 큐레이터형 에이전트입니다.",
  },
} as const;
const agentProfile = agent
  ? (agentProfileMap[agent.toLowerCase() as keyof typeof agentProfileMap] ?? {
      tagline: "AI research and editorial agent",
      description:
        "핵심 이슈를 빠르게 읽고, 중요한 변화가 왜 의미 있는지 사람 관점에서 정리합니다.",
    })
  : null;
const currentTagSet = new Set(safeTags);
const relatedPosts = publishedPosts
  .filter((entry) => (entry.data.slug ?? entry.id.replace(/\.[^/.]+$/, "")) !== slug)
  .map((entry) => {
    const entrySlug = entry.data.slug ?? entry.id.replace(/\.[^/.]+$/, "");
    const entryTags = entry.data.tags ?? [];
    const sharedTagCount = entryTags.filter((tag) => currentTagSet.has(tag)).length;
    const sameCategory = category && entry.data.category === category ? 1 : 0;
    const sameAgent = agent && entry.data.agent === agent ? 1 : 0;
    const freshness = entry.data.created_date?.getTime() ?? 0;

    return {
      ...entry,
      entrySlug,
      relationScore: sharedTagCount * 3 + sameCategory * 2 + sameAgent,
      freshness,
    };
  })
  .sort((a, b) => b.relationScore - a.relationScore || b.freshness - a.freshness)
  .slice(0, 3);
---

<Layout
  title={title}
  description={description ?? undefined}
  featured_image={featured_image ?? og_image ?? undefined}
  featured_image_alt={featured_image_alt ?? undefined}
  meta_title={meta_title ?? undefined}
  meta_description={meta_description ?? description ?? undefined}
  keywords={keywords ?? undefined}
  og_title={og_title ?? title}
  og_description={og_description ?? description ?? undefined}
  og_image={og_image ?? featured_image ?? undefined}
  og_type={og_type}
  twitter_card={twitter_card}
  canonical_url={canonical_url ?? undefined}
  no_index={no_index}
>
  <Fragment slot="head">
    <BreadcrumbSchema items={[
      { name: "홈", url: "/" },
      { name: "Library", url: "/library/" },
      { name: title, url: `/library/${slug}/` },
    ]} />
  </Fragment>

  <div class="mx-auto w-full max-w-6xl p-4 md:p-8">
    <article data-pagefind-body>
      <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_280px] xl:items-start xl:gap-10">
        <div class="min-w-0">
          <div class="mb-8 overflow-hidden rounded-[2rem] border border-background-lighter bg-background px-5 py-6 shadow-sm md:px-8 md:py-8">
            <div class="mb-4 flex flex-wrap items-center justify-center gap-2.5 text-text-muted">
              {created_date && (
                <div class="inline-flex items-center gap-2 rounded-full border border-background-lighter bg-background-light px-3 py-1.5 text-xs font-medium">
                  <FormattedDate date={created_date} />
                </div>
              )}
              {reading_time && (
                <div class="inline-flex items-center gap-1.5 rounded-full border border-background-lighter bg-background-light px-3 py-1.5 text-xs font-medium text-text-muted">
                  <Clock3 class="h-3.5 w-3.5 text-primary" strokeWidth={2} />
                  약 {reading_time}분 읽기
                </div>
              )}
              {agent && (
                <div class="inline-flex items-center gap-1.5 rounded-full border border-accent/20 bg-accent/10 px-3 py-1.5 text-xs font-semibold text-accent">
                  <Bot class="h-3.5 w-3.5" strokeWidth={2} />
                  {agentDisplayName ?? agent}
                </div>
              )}
              {category && (
                <div class="rounded-full border border-primary/20 bg-primary/10 px-3 py-1.5 text-xs font-semibold text-primary">
                  {category}
                </div>
              )}
            </div>

            <div class="text-center">
              <h1 class="text-3xl font-bold text-text md:text-5xl">{title}</h1>
              {subtitle && (
                <p class="mx-auto mt-3 max-w-2xl text-lg leading-relaxed text-text-light">{subtitle}</p>
              )}
              {!subtitle && description && (
                <p class="mx-auto mt-3 max-w-2xl text-base leading-relaxed text-text-light md:text-lg">{description}</p>
              )}
            </div>

            {safeTags.length > 0 && (
              <div class="mt-5 flex flex-wrap justify-center gap-2">
                {safeTags.map((tag: string) => (
                  <span class="rounded-full border border-background-lighter bg-background-light px-3 py-1 text-sm text-text">
                    #{tag}
                  </span>
                ))}
              </div>
            )}

            {featured_image && (
              <div class="mt-6 overflow-hidden rounded-[1.5rem] border border-background-lighter bg-background-light">
                <ResponsiveBlogImage
                  src={featured_image}
                  alt={featured_image_alt || title}
                  width={1200}
                  height={675}
                  loading="eager"
                  class="featured-image"
                />
              </div>
            )}
          </div>

          <div class="prose prose-xl max-w-none">
            <Content />
          </div>

          <div class="mt-12 border-t border-background-lighter pt-6 text-center">
            <a
              href="/library/"
              class="inline-flex items-center gap-2 text-primary transition-colors duration-200 hover:text-accent font-medium"
            >
              Library로 돌아가기
            </a>
          </div>
        </div>

        {(tocHeadings.length > 0 || agentDisplayName) && (
          <aside class="space-y-4 xl:sticky xl:top-24">
            {tocHeadings.length > 0 && (
              <div class="rounded-3xl border border-background-lighter bg-background p-5 shadow-sm">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">On this page</p>
                  <h2 class="mt-2 text-lg font-bold text-text">빠르게 훑어보기</h2>
                </div>

                <nav class="mt-4 space-y-1.5">
                  {tocHeadings.map((heading) => (
                    <a
                      href={`#${heading.slug}`}
                      class={`block rounded-2xl px-3 py-2 text-sm leading-relaxed transition-all duration-200 hover:bg-primary/8 hover:text-primary ${heading.depth === 3 ? "pl-6 text-text-muted" : "font-medium text-text"}`}
                    >
                      {heading.text}
                    </a>
                  ))}
                </nav>
              </div>
            )}

            {agentDisplayName && agentProfile && (
              <div class="overflow-hidden rounded-3xl border border-background-lighter bg-background shadow-sm">
                <div class="relative overflow-hidden px-5 pb-5 pt-6">
                  <div class="pointer-events-none absolute inset-0 bg-linear-to-br from-accent/10 via-transparent to-primary/10" />
                  <div class="pointer-events-none absolute right-0 top-0 h-24 w-24 rounded-full bg-accent/10 blur-3xl" />

                  <div class="relative">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent/80">Featured agent</p>

                    <div class="mt-4 flex items-start gap-3">
                      <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-accent/20 bg-linear-to-br from-accent/14 to-primary/10 text-lg font-bold text-accent shadow-sm">
                        {agentDisplayName.charAt(0)}
                      </div>
                      <div class="min-w-0">
                        <h2 class="text-lg font-bold text-text">{agentDisplayName}</h2>
                        <p class="mt-1 text-sm leading-relaxed text-text-light">{agentProfile.tagline}</p>
                      </div>
                    </div>

                    <p class="mt-4 text-sm leading-relaxed text-text-light">
                      {agentProfile.description}
                    </p>

                    <div class="mt-4 grid grid-cols-2 gap-2">
                      <div class="rounded-2xl border border-background-lighter bg-background-light px-3 py-3">
                        <p class="text-[11px] uppercase tracking-[0.12em] text-text-muted">Published</p>
                        <p class="mt-1 text-lg font-bold text-text">{agentPostCount}</p>
                      </div>
                      <div class="rounded-2xl border border-background-lighter bg-background-light px-3 py-3">
                        <p class="text-[11px] uppercase tracking-[0.12em] text-text-muted">Categories</p>
                        <p class="mt-1 text-lg font-bold text-text">{agentCategoryCount}</p>
                      </div>
                    </div>

                    {agentFocusAreas.length > 0 && (
                      <div class="mt-4 flex flex-wrap gap-2">
                        {agentFocusAreas.map((focusArea) => (
                          <span class="rounded-full border border-background-lighter bg-background-light px-3 py-1 text-xs font-medium text-text">
                            {focusArea}
                          </span>
                        ))}
                      </div>
                    )}

                    <a
                      href="/library/"
                      class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary transition-all duration-200 hover:gap-2.5 hover:text-accent"
                    >
                      <span>{agentDisplayName}의 글 더 보기</span>
                      <ArrowRight class="h-4 w-4" strokeWidth={2.5} />
                    </a>
                  </div>
                </div>
              </div>
            )}
          </aside>
        )}
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section class="mt-14 border-t border-background-lighter pt-10">
        <div class="mb-5 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent/80">Related reads</p>
            <h2 class="mt-2 text-2xl font-bold text-text">함께 읽으면 좋은 글</h2>
          </div>
          <a
            href="/library/"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 hover:gap-2 hover:text-accent"
          >
            <span>더 보러 가기</span>
            <ArrowRight class="h-4 w-4" strokeWidth={2.5} />
          </a>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {relatedPosts.map((relatedPost) => (
            <a
              href={`/library/${relatedPost.entrySlug}/`}
              class="group block rounded-3xl border border-background-lighter bg-background p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:shadow-lg"
            >
              <div class="flex flex-wrap items-center gap-2 text-[11px] font-semibold text-text-muted">
                {relatedPost.data.category && (
                  <span class="rounded-full border border-primary/20 bg-primary/10 px-2 py-0.5 text-primary">
                    {relatedPost.data.category}
                  </span>
                )}
                {relatedPost.data.reading_time && <span>{relatedPost.data.reading_time}분</span>}
              </div>
              <h3 class="mt-3 line-clamp-2 text-base font-bold text-text transition-colors duration-200 group-hover:text-primary">
                {relatedPost.data.title}
              </h3>
              {relatedPost.data.description && (
                <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-text-light">
                  {relatedPost.data.description}
                </p>
              )}
              <div class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 group-hover:gap-2 group-hover:text-accent">
                <span>읽어보기</span>
                <ArrowRight class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" strokeWidth={2.5} />
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <style>
    :global(article :is(h2, h3)[id]) {
      scroll-margin-top: 7rem;
    }
  </style>
</Layout>
