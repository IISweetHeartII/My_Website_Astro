---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import { Bot } from "lucide-astro";
import Layout from "@/layouts/Layout.astro";
import BreadcrumbSchema from "@/shared/components/seo/BreadcrumbSchema.astro";
import FormattedDate from "@/shared/components/ui/FormattedDate.astro";
import ResponsiveBlogImage from "@/shared/components/ui/ResponsiveBlogImage.astro";

export const getStaticPaths = (async () => {
  const posts = await getCollection("library");
  return posts
    .filter((post) => post.data.publish)
    .map((post) => {
      const slug = post.data.slug ?? post.id.replace(/\.[^/.]+$/, "");
      return { params: { slug }, props: { post } };
    });
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const {
  title,
  description,
  created_date,
  featured_image,
  featured_image_alt,
  tags,
  agent,
  category,
} = post.data;

const safeTags = tags ?? [];
const slug = post.data.slug ?? post.id.replace(/\.[^/.]+$/, "");
---

<Layout
  title={title}
  description={description ?? undefined}
  featured_image={featured_image ?? undefined}
  featured_image_alt={featured_image_alt ?? undefined}
  og_type="article"
>
  <Fragment slot="head">
    <BreadcrumbSchema items={[
      { name: "홈", url: "/" },
      { name: "Library", url: "/library/" },
      { name: title, url: `/library/${slug}/` },
    ]} />
  </Fragment>

  <div class="w-full max-w-4xl mx-auto p-4 md:p-8">
    <article data-pagefind-body>
      <div class="mb-8 text-center">
        {created_date && (
          <div class="text-text-muted mb-3 flex items-center justify-center gap-3 flex-wrap">
            <FormattedDate date={created_date} />
            {agent && (
              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent/10 text-accent border border-accent/20">
                <Bot class="w-3 h-3" strokeWidth={2} />
                {agent}
              </span>
            )}
            {category && (
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
                {category}
              </span>
            )}
          </div>
        )}
        <h1 class="text-3xl md:text-4xl font-bold text-text mb-3">{title}</h1>
        {safeTags.length > 0 && (
          <div class="flex flex-wrap gap-2 justify-center mt-4">
            {safeTags.map((tag: string) => (
              <span class="bg-background-light text-text px-3 py-0.5 rounded-full text-sm">
                #{tag}
              </span>
            ))}
          </div>
        )}
        {featured_image && (
          <div class="mt-6">
            <ResponsiveBlogImage
              src={featured_image}
              alt={featured_image_alt || title}
              width={1200}
              height={675}
              loading="eager"
              class="featured-image"
            />
          </div>
        )}
      </div>

      <div class="prose prose-xl max-w-none">
        <Content />
      </div>

      <div class="mt-12 pt-6 border-t border-background-lighter text-center">
        <a
          href="/library/"
          class="inline-flex items-center gap-2 text-primary hover:text-accent font-medium transition-colors duration-200"
        >
          Library로 돌아가기
        </a>
      </div>
    </article>
  </div>
</Layout>
