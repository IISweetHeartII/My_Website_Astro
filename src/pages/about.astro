---
import { SITE_URL } from "@/shared/config/consts";

const title = "김덕환 — A Time Capsule";
const description =
  "수학도에서 AI 활용 개발자로. 터미널로 읽거나 글로 읽는, 김덕환 인터랙티브 소개.";
const canonical = `${SITE_URL}/about`;
---

<!doctype html>
<html lang="ko" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <link rel="stylesheet" href="/fonts/pretendard-subset.css" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = stored ?? (prefersDark ? "dark" : "light");
      })();
    </script>
  </head>

  <body>
    <div class="switch" role="group" aria-label="읽기 모드">
      <a class="switch__home" href="/">← log8.kr</a>
      <button id="btn-term" class="switch__btn" aria-pressed="true">&gt;_ 터미널로 읽기</button>
      <button id="btn-read" class="switch__btn" aria-pressed="false">¶ 글로 읽기</button>
    </div>

    <header class="masthead">
      <div class="masthead__logo" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span>
        <span></span><span></span><span></span><span></span>
      </div>
      <div class="masthead__meta">
        <p class="masthead__title">김덕환</p>
        <p class="masthead__sub">A Time Capsule</p>
        <p class="masthead__sub">2020 — 2026</p>
      </div>
    </header>

    <nav class="chapters" id="chapters" aria-label="챕터"></nav>

    <main class="screen" id="screen"></main>

    <footer class="cmd" id="cmd-bar">
      <span class="cmd__prompt">&rsaquo;</span>
      <input
        id="cmd-input"
        class="cmd__input"
        type="text"
        autocomplete="off"
        spellcheck="false"
        placeholder="명령어 입력 또는 /help"
        aria-label="명령어 입력"
      />
    </footer>
    <div class="statusbar" id="statusbar">
      <span id="hint">/ 로 명령어 입력</span><span id="progress"></span>
    </div>

    <div class="modal" id="modal" hidden>
      <div class="modal__win" role="dialog" aria-modal="true" aria-label="이미지">
        <div class="modal__bar">
          <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span
          ><span class="modal__title" id="modal-title"></span>
        </div>
        <div class="modal__body" id="modal-body"></div>
      </div>
    </div>

    <style is:global>
      :root {
        --t-bg: #0a0b12;
        --t-panel: #0e1018;
        --t-fg: #c7c9d6;
        --t-dim: #626678;
        --t-accent: #9b8cf0; /* log8.kr 브랜드 보라 (periwinkle) */
        --t-cyan: #6db9cc;
        --t-green: #82ab63;
        --t-line: #1c1e2b;
        /* article (light) */
        --bg: #ffffff;
        --surface: #faf5ff;
        --ink: #1a1a2e;
        --muted: #4a5568;
        --line: #ece5f6;
        --accent: #7c3aed;
        --accent-soft: #7c3aed;
        --sans: "Pretendard", -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", system-ui,
          sans-serif;
        --mono: ui-monospace, "SF Mono", "JetBrains Mono", "Menlo", monospace;
        --maxw: 52rem;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #14121c;
          --surface: #1c1930;
          --ink: #ece5f6;
          --muted: #a99ec2;
          --line: #2b2540;
          --accent: #a78bfa;
          --accent-soft: #a78bfa;
        }
      }
      :root[data-theme="dark"] {
        --bg: #14121c;
        --surface: #1c1930;
        --ink: #ece5f6;
        --muted: #a99ec2;
        --line: #2b2540;
        --accent: #a78bfa;
        --accent-soft: #a78bfa;
      }
      :root[data-theme="light"] {
        --bg: #ffffff;
        --surface: #faf5ff;
        --ink: #1a1a2e;
        --muted: #4a5568;
        --line: #ece5f6;
        --accent: #7c3aed;
        --accent-soft: #7c3aed;
      }

      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--sans);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        display: flex;
        flex-direction: column;
        transition:
          background 0.3s ease,
          color 0.3s ease;
      }

      .switch {
        position: sticky;
        top: 0;
        z-index: 20;
        display: flex;
        gap: 0.4rem;
        align-items: center;
        padding: 0.8rem clamp(1rem, 4vw, 2rem);
        background: color-mix(in srgb, var(--bg) 85%, transparent);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--line);
      }
      .switch__home {
        font-family: var(--mono);
        font-size: 0.82rem;
        color: var(--muted);
        text-decoration: none;
        margin-right: auto;
      }
      .switch__home:hover {
        color: var(--accent);
      }
      .switch__btn {
        font-family: var(--mono);
        font-size: 0.82rem;
        letter-spacing: 0.02em;
        padding: 0.45rem 0.85rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition: all 0.18s ease;
      }
      .switch__btn:hover {
        color: var(--ink);
        border-color: var(--accent);
      }
      .switch__btn[aria-pressed="true"] {
        color: #fff;
        background: var(--accent);
        border-color: var(--accent);
      }
      .switch__btn:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .masthead {
        display: flex;
        align-items: center;
        gap: 1rem;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: clamp(1.4rem, 4vw, 2.2rem) clamp(1.1rem, 4vw, 1.6rem) 1rem;
      }
      .masthead__logo {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: 1fr;
        width: 56px;
        height: 42px;
        gap: 2px;
        flex: none;
      }
      .masthead__logo span {
        background: var(--accent);
        border-radius: 2px;
      }
      .masthead__logo span:nth-child(1),
      .masthead__logo span:nth-child(4),
      .masthead__logo span:nth-child(9),
      .masthead__logo span:nth-child(12) {
        background: transparent;
      }
      .masthead__logo span:nth-child(6),
      .masthead__logo span:nth-child(7) {
        background: var(--bg);
      }
      .masthead__title {
        font-family: var(--mono);
        font-weight: 700;
        margin: 0;
        font-size: 1.05rem;
      }
      .masthead__sub {
        font-family: var(--mono);
        margin: 0;
        font-size: 0.82rem;
        color: var(--muted);
      }

      .chapters {
        display: flex;
        gap: 0.15rem;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: 0.4rem clamp(1.1rem, 4vw, 1.6rem);
        overflow-x: auto;
        border-bottom: 1px solid var(--line);
        scrollbar-width: thin;
      }
      .chapters::-webkit-scrollbar {
        height: 0;
      }
      .chip {
        font-family: var(--mono);
        font-size: 0.85rem;
        white-space: nowrap;
        padding: 0.3rem 0.6rem;
        border: none;
        background: none;
        color: var(--muted);
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.15s ease;
      }
      .chip:hover {
        color: var(--ink);
      }
      .chip[aria-current="true"] {
        color: var(--ink);
        background: color-mix(in srgb, var(--accent) 22%, transparent);
      }
      .chip:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 1px;
      }
      .chapters__arrows {
        margin-left: auto;
        color: var(--t-dim);
        font-family: var(--mono);
        font-size: 0.8rem;
        align-self: center;
        padding-left: 0.5rem;
        flex: none;
      }

      .screen {
        flex: 1;
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        padding: 1.6rem clamp(1.1rem, 4vw, 1.6rem) 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.15rem;
        font-family: var(--mono);
        font-size: 0.98rem;
        line-height: 1.75;
      }
      .ln {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
      }
      .ln--p {
        color: var(--ink);
      }
      .ln--speaker {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }
      .ln--speaker .who {
        color: var(--t-cyan);
        font-weight: 700;
      }
      .ln--speaker .who::before {
        content: "● ";
        color: var(--t-green);
      }
      .ln--speaker .said {
        color: var(--ink);
      }
      .hr {
        border: none;
        border-top: 1px solid var(--line);
        margin: 0.4rem 0;
      }
      .caret {
        display: inline-block;
        width: 0.55rem;
        height: 1.05em;
        vertical-align: text-bottom;
        background: var(--accent);
        animation: blink 1.05s steps(1) infinite;
      }
      @keyframes blink {
        50% {
          opacity: 0;
        }
      }

      .kv {
        display: flex;
        gap: 0.6rem;
        align-items: baseline;
      }
      .kv__k {
        color: var(--t-dim);
        min-width: 8.5rem;
      }
      .kv__k::after {
        content: " ....";
        color: var(--line);
      }
      .kv__v {
        color: var(--t-green);
      }
      .kv__v .u {
        color: var(--accent-soft);
      }
      .proj .kv__k {
        color: var(--t-cyan);
        min-width: 8.5rem;
      }
      .proj .kv__k::after {
        content: "";
      }
      .proj .kv__v {
        color: var(--muted);
      }

      .choice {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .choice__q {
        color: var(--ink);
        margin: 0 0 0.2rem;
      }
      .opt {
        display: flex;
        gap: 0.5rem;
        align-items: baseline;
        padding: 0.1rem 0.3rem;
        border-radius: 5px;
        color: var(--muted);
        cursor: pointer;
        background: none;
        border: none;
        font: inherit;
        text-align: left;
        width: 100%;
      }
      .opt .arrow {
        color: transparent;
      }
      .opt[data-active="true"] {
        color: var(--ink);
      }
      .opt[data-active="true"] .arrow {
        color: var(--accent);
      }
      .opt[data-active="true"] .lbl {
        color: var(--accent-soft);
      }
      .opt .num {
        color: var(--t-dim);
      }
      .choice__hint {
        color: var(--t-dim);
        font-size: 0.82rem;
        margin: 0.15rem 0 0;
      }
      .links {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }
      .links a {
        color: var(--t-cyan);
        text-decoration: none;
        border-bottom: 1px dotted var(--t-dim);
      }
      .links a:hover {
        color: var(--accent);
        border-color: var(--accent);
      }
      .imglink {
        background: none;
        border: none;
        font: inherit;
        color: var(--t-green);
        cursor: pointer;
        padding: 0;
      }
      .imglink u {
        color: var(--t-cyan);
      }

      .cmd {
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        display: flex;
        gap: 0.5rem;
        align-items: center;
        padding: 0.7rem clamp(1.1rem, 4vw, 1.6rem);
        border-top: 1px solid var(--line);
        font-family: var(--mono);
      }
      .cmd__prompt {
        color: var(--accent);
      }
      .cmd__input {
        flex: 1;
        background: none;
        border: none;
        color: var(--ink);
        font: inherit;
        outline: none;
      }
      .cmd__input::placeholder {
        color: var(--t-dim);
      }
      .statusbar {
        max-width: var(--maxw);
        width: 100%;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        padding: 0.3rem clamp(1.1rem, 4vw, 1.6rem) 1rem;
        font-family: var(--mono);
        font-size: 0.78rem;
        color: var(--t-dim);
      }

      :root[data-view="terminal"] body {
        background: var(--t-bg);
        color: var(--t-fg);
      }
      :root[data-view="terminal"] .ln--p,
      :root[data-view="terminal"] .ln--speaker .said,
      :root[data-view="terminal"] .choice__q {
        color: var(--t-fg);
      }
      :root[data-view="terminal"] .masthead__logo span {
        background: var(--t-accent);
      }
      :root[data-view="terminal"] .masthead__logo span:nth-child(6),
      :root[data-view="terminal"] .masthead__logo span:nth-child(7) {
        background: var(--t-bg);
      }
      :root[data-view="terminal"] .switch,
      :root[data-view="terminal"] .chapters,
      :root[data-view="terminal"] .cmd {
        border-color: var(--t-line);
      }
      :root[data-view="terminal"] .switch {
        background: color-mix(in srgb, var(--t-bg) 82%, transparent);
      }
      :root[data-view="terminal"] .switch__home {
        color: var(--t-dim);
      }
      :root[data-view="terminal"] .switch__home:hover {
        color: var(--t-accent);
      }
      :root[data-view="terminal"] .switch__btn {
        color: var(--t-dim);
        border-color: var(--t-line);
      }
      :root[data-view="terminal"] .switch__btn[aria-pressed="true"] {
        color: var(--t-bg);
        background: var(--t-accent);
        border-color: var(--t-accent);
      }
      :root[data-view="terminal"] .chip[aria-current="true"] {
        background: color-mix(in srgb, var(--t-accent) 26%, transparent);
        color: #fff;
      }
      :root[data-view="terminal"] .hr,
      :root[data-view="terminal"] .kv__k::after {
        border-color: var(--t-line);
      }
      :root[data-view="terminal"] .kv__k::after {
        content: " ....";
        color: var(--t-line);
      }
      :root[data-view="terminal"] .caret {
        background: var(--t-accent);
      }
      :root[data-view="terminal"] .opt[data-active="true"] .arrow,
      :root[data-view="terminal"] .cmd__prompt {
        color: var(--t-accent);
      }
      :root[data-view="terminal"] .opt[data-active="true"] .lbl {
        color: var(--t-accent);
      }
      :root[data-view="terminal"] .cmd__input {
        color: var(--t-fg);
      }

      :root[data-view="article"] .cmd,
      :root[data-view="article"] .statusbar,
      :root[data-view="article"] .chapters__arrows {
        display: none;
      }
      :root[data-view="article"] .screen {
        font-family: var(--sans);
        font-size: 1.05rem;
      }
      :root[data-view="article"] .caret {
        display: none;
      }
      :root[data-view="article"] .choice__hint {
        display: none;
      }
      .ch-head {
        display: none;
      }
      :root[data-view="article"] .ch-head {
        display: block;
        font-family: var(--mono);
        font-size: 0.8rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent-soft);
        margin: 1.4rem 0 0.2rem;
      }

      .modal {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        background: rgba(3, 4, 7, 0.72);
        backdrop-filter: blur(3px);
      }
      .modal[hidden] {
        display: none;
      }
      .modal__win {
        width: min(680px, 100%);
        background: #161a22;
        border: 1px solid #2a2f3b;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
      }
      .modal__bar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 0.8rem;
        background: #1d222c;
        border-bottom: 1px solid #2a2f3b;
        font-family: var(--mono);
      }
      .dot {
        width: 0.72rem;
        height: 0.72rem;
        border-radius: 50%;
      }
      .dot.r {
        background: #ff5f57;
      }
      .dot.y {
        background: #febc2e;
      }
      .dot.g {
        background: #28c840;
      }
      .modal__title {
        margin-left: 0.6rem;
        color: #8b93a3;
        font-size: 0.85rem;
      }
      .modal__body {
        padding: 1rem;
        background: #fff;
      }
      .modal__body svg {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 4px;
      }
      .modal__body figcaption {
        font-family: var(--mono);
        font-size: 0.8rem;
        color: #555;
        margin: 0.6rem 0.2rem 0;
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          transition: none !important;
        }
        .caret {
          animation: none;
        }
      }
    </style>

    <script is:inline>
      (function () {
        var root = document.documentElement;
        var reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

        function catSVG(x, y, c) {
          return (
            '<g transform="translate(' +
            x +
            "," +
            y +
            ')">' +
            '<polygon points="4,0 14,22 -6,22" fill="' +
            c +
            '"/>' +
            '<polygon points="56,0 66,22 46,22" fill="' +
            c +
            '"/>' +
            '<rect x="-8" y="18" width="76" height="60" rx="16" fill="' +
            c +
            '"/>' +
            '<circle cx="14" cy="44" r="6" fill="#1a1a1a"/>' +
            '<circle cx="46" cy="44" r="6" fill="#1a1a1a"/>' +
            '<polygon points="30,52 24,60 36,60" fill="#1a1a1a"/></g>'
          );
        }
        var fleetSVG =
          '<svg viewBox="0 0 640 380" xmlns="http://www.w3.org/2000/svg">' +
          '<rect width="640" height="380" fill="#fbfbfb"/>' +
          '<rect x="210" y="250" width="220" height="70" rx="10" fill="#c9ccd2"/>' +
          '<rect x="210" y="250" width="220" height="70" rx="10" fill="none" stroke="#a7abb4" stroke-width="2"/>' +
          '<circle cx="320" cy="285" r="9" fill="#8b8f98"/>' +
          '<rect x="230" y="300" width="180" height="4" rx="2" fill="#b3b7bf"/>' +
          catSVG(120, 150, "#9b8cf0") +
          catSVG(210, 120, "#82ab63") +
          catSVG(300, 140, "#6db9cc") +
          catSVG(390, 120, "#e6a94a") +
          catSVG(470, 150, "#e2725b") +
          "</svg>";

        var CHAPTERS = [
          {
            id: "I. 시작",
            blocks: [
              { t: "p", text: "저는 숫자로 세상을 봤습니다. 수학과에서 증명과 구조에 빠져 살았죠." },
              {
                t: "p",
                text: "증명은 아름다웠지만, 아무도 그걸 쓰지는 못했습니다. 저는 점점 '풀리는 문제'보다 '누군가에게 닿는 문제'가 궁금해졌어요.",
              },
              {
                t: "choice",
                q: "그때 이야기, 조금 더 볼까요?",
                yes: {
                  label: "네, 보여줘",
                  reveal: [
                    {
                      t: "p",
                      text: "밤마다 터미널을 열고 코드를 썼습니다. 처음엔 서툴렀지만, 무언가가 실제로 '동작'하는 감각이 좋았어요. 증명의 끝은 QED였지만, 코드의 끝은 사람이었으니까요.",
                    },
                  ],
                },
                skip: { label: "건너뛰기" },
              },
            ],
          },
          {
            id: "II. 전환",
            blocks: [
              {
                t: "speaker",
                who: "@김덕환",
                said: "AI에게 처음 제대로 된 일을 시켰던 순간을 기억합니다. RFC 문서를 통째로 던져주고 '이거 구현해줘' 했더니 — 정말로 해내더군요.",
              },
              {
                t: "p",
                text: "그날 이후 저는 '코드를 쓰는 사람'에서 'AI가 코드를 쓰게 만드는 사람'으로 바뀌었습니다. 도구가 아니라, 팀을 얻은 기분이었어요.",
              },
            ],
          },
          {
            id: "III. 함대",
            blocks: [
              {
                t: "p",
                text: "지금 저는 혼자 일하지 않습니다. 맥미니 한 대 위에서 에이전트 다섯이 24시간 돌아갑니다. 각자 맡은 일이 있고, 서로 문서로 대화합니다.",
              },
              {
                t: "kv",
                cls: "proj",
                items: [
                  { k: "rosie", v: "오케스트레이션 · 리뷰 (head)" },
                  { k: "kkami", v: "헬스 · 인프라" },
                  { k: "navi", v: "코드 리뷰어" },
                  { k: "luna", v: "리서치 · 콘텐츠" },
                  { k: "mover", v: "모멘텀 트레이딩" },
                ],
              },
              {
                t: "choice",
                q: "함대를 볼까요?",
                yes: {
                  label: "네, 보여줘",
                  img: { title: "the-fleet.png", cap: "맥미니 위의 에이전트들 — 각자의 자리에서", svg: "FLEET" },
                },
                skip: { label: "건너뛰기" },
              },
            ],
          },
          {
            id: "IV. 만든 것들",
            blocks: [
              {
                t: "kv",
                cls: "proj",
                items: [
                  { k: "log8.kr", v: "Astro 개인 블로그 · 에이전트 자율 발행 라이브러리" },
                  { k: "Hermes Fleet", v: "멀티 에이전트 오케스트레이션 네트워크" },
                  { k: "crawler stack", v: "curl_cffi · patchright 데이터 수집 파이프라인" },
                  { k: "Mover", v: "실계좌 라이브 모멘텀 트레이딩 에이전트" },
                ],
              },
            ],
          },
          {
            id: "V. 임팩트",
            blocks: [
              {
                t: "p",
                text: "숫자로 세상을 보던 습관은 아직 남아 있습니다. 다만 이제는 증명이 아니라, 만든 것의 결과를 셉니다.",
              },
              {
                t: "kv",
                items: [
                  { k: "코드리뷰 처리량", v: "400<span class='u'>%↑</span>" },
                  { k: "장애 복구 시간", v: "56h → 5h" },
                  { k: "개발 속도", v: "7<span class='u'>×</span>" },
                  { k: "설계 구조 품질", v: "7<span class='u'>×</span>" },
                  { k: "학습 효율", v: "3<span class='u'>×</span>" },
                ],
              },
            ],
          },
          {
            id: "VI. 지금",
            blocks: [
              {
                t: "p",
                text: "겨울 2025부터, 저는 대부분의 코드를 제 손으로 직접 쓰지 않습니다. 대신 방향을 정하고, 검증하고 — 에이전트들이 그 사이를 채웁니다.",
              },
              {
                t: "speaker",
                who: "@김덕환",
                said: "도구는 계속 진화합니다. IBM 029 천공기에서 ed로, 그리고 지금의 에이전트로. 저는 그 스펙트럼 어딘가에서, 다음을 만들고 있습니다.",
              },
            ],
          },
          {
            id: "VII. 연락",
            blocks: [
              { t: "p", text: "시간 캡슐은 여기까지입니다. 다음 장은 아직 쓰이지 않았어요." },
              {
                t: "links",
                items: [
                  { label: "log8.kr", href: "https://log8.kr" },
                  { label: "github.com/IISweetHeartII", href: "https://github.com/IISweetHeartII" },
                ],
              },
              { t: "end" },
            ],
          },
        ];

        var elChapters = document.getElementById("chapters");
        var elScreen = document.getElementById("screen");
        var elCmd = document.getElementById("cmd-input");
        var elProgress = document.getElementById("progress");
        var elModal = document.getElementById("modal");
        var elModalTitle = document.getElementById("modal-title");
        var elModalBody = document.getElementById("modal-body");
        var bTerm = document.getElementById("btn-term");
        var bRead = document.getElementById("btn-read");

        var current = 0;
        var renderToken = 0;

        function sleep(ms) {
          return new Promise(function (r) {
            setTimeout(r, ms);
          });
        }
        function esc(s) {
          return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
        }
        function elP() {
          var p = document.createElement("p");
          p.className = "ln ln--p";
          return p;
        }

        CHAPTERS.forEach(function (ch, i) {
          var b = document.createElement("button");
          b.className = "chip";
          b.type = "button";
          b.textContent = ch.id;
          b.addEventListener("click", function () {
            go(i);
          });
          elChapters.appendChild(b);
        });
        var arrows = document.createElement("span");
        arrows.className = "chapters__arrows";
        arrows.textContent = "(←/→)";
        elChapters.appendChild(arrows);

        function markChips() {
          var chips = elChapters.querySelectorAll(".chip");
          chips.forEach(function (c, i) {
            c.setAttribute("aria-current", String(i === current));
          });
          elProgress.textContent = "Chapter " + (current + 1) + " of " + CHAPTERS.length;
        }

        function buildStatic(block, container) {
          if (block.t === "p") {
            var p = elP();
            p.innerHTML = esc(block.text);
            container.appendChild(p);
          } else if (block.t === "speaker") {
            var w = document.createElement("div");
            w.className = "ln ln--speaker";
            w.innerHTML =
              '<span class="who">' + esc(block.who) + '</span><span class="said">' + esc(block.said) + "</span>";
            container.appendChild(w);
          } else if (block.t === "kv") {
            var box = document.createElement("div");
            box.style.display = "flex";
            box.style.flexDirection = "column";
            box.style.gap = ".2rem";
            if (block.cls) box.className = block.cls;
            block.items.forEach(function (it) {
              var row = document.createElement("div");
              row.className = "kv" + (block.cls ? " " + block.cls : "");
              row.innerHTML = '<span class="kv__k">' + esc(it.k) + '</span><span class="kv__v">' + it.v + "</span>";
              box.appendChild(row);
            });
            container.appendChild(box);
          } else if (block.t === "links") {
            var ul = document.createElement("div");
            ul.className = "links";
            block.items.forEach(function (it) {
              var a = document.createElement("a");
              a.href = it.href;
              a.textContent = it.label;
              a.target = "_blank";
              a.rel = "noopener";
              ul.appendChild(a);
            });
            container.appendChild(ul);
          } else if (block.t === "end") {
            var e = document.createElement("p");
            e.className = "ln";
            e.innerHTML = '<span class="caret"></span>';
            container.appendChild(e);
          }
        }

        function openModal(img) {
          elModalTitle.textContent = img.title || "image";
          elModalBody.innerHTML =
            '<figure style="margin:0">' +
            (img.svg === "FLEET" ? fleetSVG : "") +
            "<figcaption>" +
            esc(img.cap || "") +
            "</figcaption></figure>";
          elModal.hidden = false;
        }
        function closeModal() {
          elModal.hidden = true;
        }

        async function typeInto(node, html, tok, sig) {
          if (reduce) {
            node.innerHTML = html;
            return;
          }
          var tmp = document.createElement("span");
          tmp.innerHTML = html;
          var text = tmp.textContent;
          for (var i = 0; i < text.length; i++) {
            if (tok !== renderToken) return;
            if (sig.skip) {
              node.innerHTML = html;
              return;
            }
            node.appendChild(document.createTextNode(text[i]));
            var ch = text[i];
            await sleep(ch === " " ? 6 : /[.,—]/.test(ch) ? 70 : 14);
          }
          node.innerHTML = html;
        }

        function waitChoice(block, wrap, tok) {
          return new Promise(function (resolve) {
            var opts = [
              { label: block.yes.label, kind: "yes" },
              { label: block.skip.label, kind: "skip" },
            ];
            var active = 0;
            var btns = [];
            var q = document.createElement("p");
            q.className = "choice__q";
            q.textContent = block.q;
            wrap.appendChild(q);
            opts.forEach(function (o, i) {
              var b = document.createElement("button");
              b.type = "button";
              b.className = "opt";
              b.innerHTML =
                '<span class="arrow">›</span><span class="num">' +
                (i + 1) +
                '.</span><span class="lbl">' +
                esc(o.label) +
                "</span>";
              b.addEventListener("mouseenter", function () {
                active = i;
                paint();
              });
              b.addEventListener("click", function () {
                choose(i);
              });
              wrap.appendChild(b);
              btns.push(b);
            });
            var hint = document.createElement("p");
            hint.className = "choice__hint";
            hint.textContent = "1/2 또는 Enter 선택 · ↑/↓ 이동";
            wrap.appendChild(hint);
            function paint() {
              btns.forEach(function (b, i) {
                b.setAttribute("data-active", String(i === active));
              });
            }
            paint();
            function choose(i) {
              cleanup();
              resolve(opts[i].kind);
            }
            function onKey(e) {
              if (tok !== renderToken) {
                cleanup();
                return;
              }
              if (e.key === "ArrowDown" || e.key === "ArrowUp") {
                active = (active + 1) % 2;
                paint();
                e.preventDefault();
              } else if (e.key === "1") {
                choose(0);
                e.preventDefault();
              } else if (e.key === "2") {
                choose(1);
                e.preventDefault();
              } else if (e.key === "Enter") {
                choose(active);
                e.preventDefault();
              }
            }
            function cleanup() {
              document.removeEventListener("keydown", onKey, true);
              wrap._choiceActive = false;
            }
            wrap._choiceActive = true;
            document.addEventListener("keydown", onKey, true);
          });
        }

        async function streamChapter(i) {
          var tok = ++renderToken;
          var sig = { skip: false };
          elScreen.innerHTML = "";
          var blocks = CHAPTERS[i].blocks;
          for (var b = 0; b < blocks.length; b++) {
            if (tok !== renderToken) return;
            var block = blocks[b];
            if (block.t === "p") {
              var p = elP();
              elScreen.appendChild(p);
              await typeInto(p, esc(block.text), tok, sig);
            } else if (block.t === "speaker") {
              var w = document.createElement("div");
              w.className = "ln ln--speaker";
              var who = document.createElement("span");
              who.className = "who";
              who.textContent = block.who;
              var said = document.createElement("span");
              said.className = "said";
              w.appendChild(who);
              w.appendChild(said);
              elScreen.appendChild(w);
              await typeInto(said, esc(block.said), tok, sig);
            } else if (block.t === "kv" || block.t === "links" || block.t === "end") {
              buildStatic(block, elScreen);
              if (!sig.skip && !reduce) await sleep(120);
            } else if (block.t === "choice") {
              sig.skip = false;
              var wrap = document.createElement("div");
              wrap.className = "choice";
              elScreen.appendChild(wrap);
              var pick = await waitChoice(block, wrap, tok);
              if (tok !== renderToken) return;
              var h = wrap.querySelector(".choice__hint");
              if (h) h.remove();
              if (pick === "yes") {
                if (block.yes.img) openModal(block.yes.img);
                if (block.yes.reveal) {
                  for (var r = 0; r < block.yes.reveal.length; r++) {
                    var rb = block.yes.reveal[r];
                    if (rb.t === "p") {
                      var rp = elP();
                      elScreen.appendChild(rp);
                      await typeInto(rp, esc(rb.text), tok, sig);
                    } else {
                      buildStatic(rb, elScreen);
                    }
                  }
                }
              }
            }
            if (tok !== renderToken) return;
            if (!sig.skip && !reduce) await sleep(90);
          }
        }

        function renderArticle() {
          elScreen.innerHTML = "";
          CHAPTERS.forEach(function (ch) {
            var head = document.createElement("p");
            head.className = "ch-head";
            head.textContent = ch.id;
            elScreen.appendChild(head);
            ch.blocks.forEach(function (block) {
              if (block.t === "choice") {
                if (block.yes.reveal) {
                  block.yes.reveal.forEach(function (rb) {
                    buildStatic(rb, elScreen);
                  });
                }
                if (block.yes.img) {
                  var wrap = document.createElement("div");
                  wrap.className = "links";
                  var btn = document.createElement("button");
                  btn.className = "imglink";
                  btn.innerHTML = "● Open(" + esc(block.yes.img.title) + ") — <u>Open ↗</u>";
                  btn.addEventListener("click", function () {
                    openModal(block.yes.img);
                  });
                  wrap.appendChild(btn);
                  elScreen.appendChild(wrap);
                }
              } else {
                buildStatic(block, elScreen);
              }
            });
          });
        }

        function go(i) {
          if (i < 0 || i >= CHAPTERS.length) return;
          current = i;
          markChips();
          if (root.getAttribute("data-view") === "terminal") {
            streamChapter(i);
          } else {
            var head = elScreen.querySelectorAll(".ch-head")[i];
            if (head) head.scrollIntoView({ behavior: reduce ? "auto" : "smooth", block: "start" });
          }
        }

        function setView(v) {
          root.setAttribute("data-view", v);
          var term = v === "terminal";
          bTerm.setAttribute("aria-pressed", String(term));
          bRead.setAttribute("aria-pressed", String(!term));
          try {
            localStorage.setItem("kim-tc-view", v);
          } catch (e) {}
          renderToken++;
          if (term) {
            markChips();
            streamChapter(current);
          } else {
            renderArticle();
            markChips();
          }
        }

        bTerm.addEventListener("click", function () {
          setView("terminal");
        });
        bRead.addEventListener("click", function () {
          setView("article");
        });

        function flash(msg) {
          document.getElementById("hint").textContent = msg;
        }
        function runCommand(raw) {
          var c = raw.trim().toLowerCase();
          if (!c) return;
          if (c === "/help") {
            flash("명령어: /article /terminal /next /prev /home · 1~7 챕터 이동 · ←/→ 이동");
            return;
          }
          if (c === "/article" || c === "/read") {
            setView("article");
            return;
          }
          if (c === "/terminal") {
            setView("terminal");
            return;
          }
          if (c === "/next") {
            go(current + 1);
            return;
          }
          if (c === "/prev") {
            go(current - 1);
            return;
          }
          if (c === "/home") {
            go(0);
            return;
          }
          var n = parseInt(c.replace("/", ""), 10);
          if (!isNaN(n) && n >= 1 && n <= CHAPTERS.length) {
            go(n - 1);
            return;
          }
          flash("알 수 없는 명령어: " + raw + "  — /help 를 입력해보세요");
        }
        elCmd.addEventListener("keydown", function (e) {
          if (e.key === "Enter") {
            runCommand(elCmd.value);
            elCmd.value = "";
          }
        });

        document.addEventListener("keydown", function (e) {
          if (elModal.hidden === false) {
            if (e.key === "Escape") closeModal();
            return;
          }
          if (document.activeElement === elCmd) {
            if (e.key === "Escape") elCmd.blur();
            return;
          }
          var choiceActive = elScreen.querySelector(".choice");
          var capturing = choiceActive && choiceActive._choiceActive;
          if (e.key === "/") {
            e.preventDefault();
            elCmd.focus();
            return;
          }
          if (capturing) return;
          if (e.key === "ArrowRight") go(current + 1);
          else if (e.key === "ArrowLeft") go(current - 1);
        });
        elModal.addEventListener("click", function (e) {
          if (e.target === elModal) closeModal();
        });

        var saved;
        try {
          saved = localStorage.getItem("kim-tc-view");
        } catch (e) {}
        setView(saved === "article" ? "article" : "terminal");
      })();
    </script>
  </body>
</html>
