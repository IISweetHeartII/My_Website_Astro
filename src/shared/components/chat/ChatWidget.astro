---
---

<!-- FAB Button -->
<button
  id="chat-fab"
  aria-label="채팅 열기"
  aria-expanded="false"
  aria-controls="chat-window"
>
  <!-- Chat icon -->
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
</button>

<!-- Chat Window -->
<div id="chat-window" class="chat-hidden" role="dialog" aria-label="김덕환에게 물어보세요">
  <!-- Header -->
  <div class="chat-header">
    <div class="chat-header-info">
      <div class="chat-avatar">DK</div>
      <div>
        <div class="chat-header-title">김덕환에게 물어보세요</div>
        <div class="chat-header-subtitle">AI가 답변해드려요</div>
      </div>
    </div>
    <button id="chat-close" aria-label="채팅 닫기">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Messages -->
  <div id="chat-messages" class="chat-messages">
    <div class="chat-msg chat-msg-assistant">
      <div class="chat-bubble">
        안녕하세요! 김덕환에 대해 궁금한 것이 있으시면 편하게 물어보세요.
        <br><br>
        예를 들어 프로젝트, 기술 스택, 경력 등 무엇이든 질문해주세요!
      </div>
    </div>
  </div>

  <!-- Input -->
  <div class="chat-input-area">
    <textarea
      id="chat-input"
      placeholder="메시지를 입력하세요..."
      rows="1"
      aria-label="메시지 입력"
    ></textarea>
    <button id="chat-send" aria-label="전송">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </div>
</div>

<style>
  /* FAB Button */
  #chat-fab {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-primary, #8b5cf6);
    color: #fff;
    border: none;
    cursor: pointer;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18), 0 1px 4px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  #chat-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.22);
  }

  #chat-fab:active {
    transform: scale(0.96);
  }

  /* Chat Window */
  #chat-window {
    position: fixed;
    bottom: 92px;
    right: 24px;
    width: 380px;
    height: 520px;
    background: var(--color-background, #fff);
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18), 0 2px 8px rgba(0, 0, 0, 0.08);
    z-index: 9998;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform-origin: bottom right;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease;
  }

  #chat-window.chat-hidden {
    transform: scale(0.7) translateY(30px);
    opacity: 0;
    pointer-events: none;
  }

  /* Header */
  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px;
    background: var(--color-primary, #8b5cf6);
    color: #fff;
    flex-shrink: 0;
  }

  .chat-header-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .chat-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
  }

  .chat-header-title {
    font-weight: 700;
    font-size: 15px;
  }

  .chat-header-subtitle {
    font-size: 12px;
    opacity: 0.8;
  }

  #chat-close {
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
    transition: opacity 0.15s;
  }

  #chat-close:hover {
    opacity: 1;
  }

  /* Messages */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .chat-msg {
    display: flex;
    max-width: 85%;
  }

  .chat-msg-assistant {
    align-self: flex-start;
  }

  .chat-msg-user {
    align-self: flex-end;
  }

  .chat-bubble {
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 14px;
    line-height: 1.5;
    word-break: break-word;
  }

  .chat-msg-assistant .chat-bubble {
    background: var(--color-chat-ai-bg, #f0f2f5);
    color: var(--color-text, #1a1a2e);
    border-bottom-left-radius: 4px;
  }

  .chat-msg-user .chat-bubble {
    background: var(--color-primary, #8b5cf6);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  .chat-bubble :global(a) {
    color: var(--color-primary, #8b5cf6);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .chat-msg-user .chat-bubble :global(a) {
    color: #fff;
  }

  .chat-bubble :global(code) {
    background: rgba(0, 0, 0, 0.06);
    padding: 1px 4px;
    border-radius: 3px;
    font-size: 13px;
  }

  .chat-bubble :global(strong) {
    font-weight: 600;
  }

  /* Typing indicator */
  .chat-bubble :global(.chat-typing) {
    color: var(--color-text-secondary, #888);
    font-style: italic;
  }

  .chat-bubble :global(.chat-error) {
    color: #e53e3e;
  }

  /* Input Area */
  .chat-input-area {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--color-chat-border, #e8e8e8);
    flex-shrink: 0;
  }

  #chat-input {
    flex: 1;
    border: 1px solid var(--color-chat-border, #e8e8e8);
    border-radius: 12px;
    padding: 8px 12px;
    font-size: 14px;
    line-height: 1.4;
    resize: none;
    outline: none;
    background: var(--color-background, #fff);
    color: var(--color-text, #1a1a2e);
    font-family: inherit;
    max-height: 100px;
    transition: border-color 0.15s;
  }

  #chat-input:focus {
    border-color: var(--color-primary, #8b5cf6);
  }

  #chat-input::placeholder {
    color: var(--color-text-secondary, #999);
  }

  #chat-send {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--color-primary, #8b5cf6);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: opacity 0.15s, transform 0.15s;
  }

  #chat-send:hover {
    opacity: 0.9;
    transform: scale(1.05);
  }

  #chat-send:global(.chat-send-disabled) {
    opacity: 0.5;
    pointer-events: none;
  }

  /* Dark mode overrides */
  :global(html[data-theme="dark"]) .chat-msg-assistant .chat-bubble {
    background: #313244;
  }

  :global(html[data-theme="dark"]) .chat-bubble :global(code) {
    background: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme="dark"]) .chat-input-area {
    border-top-color: #45475a;
  }

  :global(html[data-theme="dark"]) #chat-input {
    border-color: #45475a;
  }

  :global(html[data-theme="dark"]) #chat-window {
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4), 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  /* Mobile responsive */
  @media (max-width: 480px) {
    #chat-fab {
      bottom: 16px;
      right: 16px;
      width: 48px;
      height: 48px;
    }

    #chat-window {
      bottom: 0;
      right: 0;
      width: 100vw;
      height: 100dvh;
      border-radius: 0;
    }

    #chat-window.chat-hidden {
      transform: translateY(100%);
    }
  }

  /* Scrollbar */
  .chat-messages::-webkit-scrollbar {
    width: 4px;
  }

  .chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 2px;
  }

  :global(html[data-theme="dark"]) .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
  }
</style>

<script>
  import { setupChatWidget } from "@/shared/scripts/chat-widget";

  function init() {
    setupChatWidget();
  }

  document.addEventListener("astro:page-load", init);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
