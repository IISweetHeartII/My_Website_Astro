---
---

<!-- FAB Button -->
<button
  id="chat-fab"
  aria-label="채팅 열기"
  aria-expanded="false"
  aria-controls="chat-window"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
</button>

<!-- Chat Panel -->
<div id="chat-window" class="chat-hidden" role="dialog" aria-label="김덕환에게 물어보세요">
  <!-- Header -->
  <div class="chat-header">
    <div class="chat-header-info">
      <div class="chat-avatar">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
      </div>
      <div>
        <div class="chat-header-title">김덕환에게 물어보세요</div>
        <div class="chat-header-subtitle">AI가 답변해드려요</div>
      </div>
    </div>
    <button id="chat-close" aria-label="채팅 닫기">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Messages -->
  <div id="chat-messages" class="chat-messages">
    <div class="chat-msg chat-msg-assistant">
      <div class="chat-msg-avatar">AI</div>
      <div class="chat-bubble">
        안녕하세요! 김덕환에 대해 궁금한 것이 있으시면 편하게 물어보세요.
        <br><br>
        프로젝트, 기술 스택, 경력 등 무엇이든 질문해주세요!
      </div>
    </div>
  </div>

  <!-- Input -->
  <div class="chat-input-area">
    <textarea
      id="chat-input"
      placeholder="메시지를 입력하세요..."
      rows="1"
      aria-label="메시지 입력"
    ></textarea>
    <button id="chat-send" aria-label="전송">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </div>
</div>

<style>
  /* ===== FAB Button ===== */
  #chat-fab {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-primary, #8b5cf6);
    color: #fff;
    border: none;
    cursor: pointer;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18), 0 1px 4px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }

  #chat-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.22);
  }

  #chat-fab:active {
    transform: scale(0.96);
  }

  #chat-fab.chat-fab-hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.5);
  }

  /* ===== Chat Panel (사이드 패널) ===== */
  #chat-window {
    position: fixed;
    top: 64px; /* 헤더 h-16 아래 */
    right: 0;
    width: 440px;
    bottom: 0;
    background: var(--color-background, #fff);
    border-left: 1px solid var(--color-chat-border, #e5e7eb);
    z-index: 9998;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.08);
  }

  #chat-window.chat-hidden {
    transform: translateX(100%);
    opacity: 0;
    pointer-events: none;
  }

  /* ===== Header ===== */
  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    background: var(--color-primary, #8b5cf6);
    color: #fff;
    flex-shrink: 0;
  }

  .chat-header-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .chat-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
  }

  .chat-header-title {
    font-weight: 700;
    font-size: 16px;
  }

  .chat-header-subtitle {
    font-size: 12px;
    opacity: 0.8;
    margin-top: 1px;
  }

  #chat-close {
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 6px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
    transition: opacity 0.15s, background 0.15s;
  }

  #chat-close:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.15);
  }

  /* ===== Messages ===== */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .chat-msg {
    display: flex;
    gap: 10px;
    max-width: 90%;
    animation: chatFadeIn 0.3s ease;
  }

  @keyframes chatFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .chat-msg-assistant {
    align-self: flex-start;
  }

  .chat-msg-user {
    align-self: flex-end;
    flex-direction: row-reverse;
  }

  /* 메시지 아바타 */
  .chat-msg-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .chat-msg-assistant .chat-msg-avatar {
    background: var(--color-primary, #8b5cf6);
    color: #fff;
  }

  .chat-msg-user .chat-msg-avatar {
    background: var(--color-chat-user-avatar, #6366f1);
    color: #fff;
  }

  /* 말풍선 */
  .chat-bubble {
    padding: 12px 16px;
    font-size: 14px;
    line-height: 1.6;
    word-break: break-word;
  }

  .chat-msg-assistant .chat-bubble {
    background: var(--color-chat-ai-bg, #f3f4f6);
    color: var(--color-text, #1a1a2e);
    border-radius: 4px 18px 18px 18px;
  }

  .chat-msg-user .chat-bubble {
    background: var(--color-primary, #8b5cf6);
    color: #fff;
    border-radius: 18px 4px 18px 18px;
  }

  /* 말풍선 내부 요소 */
  .chat-bubble :global(a) {
    color: var(--color-primary, #8b5cf6);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .chat-msg-user .chat-bubble :global(a) {
    color: #e0e0ff;
  }

  .chat-bubble :global(code) {
    background: rgba(0, 0, 0, 0.06);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 13px;
    font-family: monospace;
  }

  .chat-bubble :global(strong) {
    font-weight: 600;
  }

  .chat-bubble :global(.chat-typing) {
    color: var(--color-text-secondary, #888);
    font-style: italic;
  }

  .chat-bubble :global(.chat-error) {
    color: #ef4444;
  }

  /* ===== Input Area ===== */
  .chat-input-area {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    padding: 16px 20px;
    border-top: 1px solid var(--color-chat-border, #e5e7eb);
    flex-shrink: 0;
    background: var(--color-background, #fff);
  }

  #chat-input {
    flex: 1;
    border: 1px solid var(--color-chat-border, #e5e7eb);
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 14px;
    line-height: 1.5;
    resize: none;
    outline: none;
    background: var(--color-background, #fff);
    color: var(--color-text, #1a1a2e);
    font-family: inherit;
    max-height: 120px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  #chat-input:focus {
    border-color: var(--color-primary, #8b5cf6);
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
  }

  #chat-input::placeholder {
    color: var(--color-text-secondary, #9ca3af);
  }

  #chat-send {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: var(--color-primary, #8b5cf6);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: opacity 0.15s, transform 0.15s;
  }

  #chat-send:hover {
    opacity: 0.9;
    transform: scale(1.05);
  }

  #chat-send:global(.chat-send-disabled) {
    opacity: 0.4;
    pointer-events: none;
  }

  /* ===== Dark Mode ===== */
  :global(html[data-theme="dark"]) #chat-window {
    border-left-color: #313244;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.3);
  }

  :global(html[data-theme="dark"]) .chat-msg-assistant .chat-bubble {
    background: #313244;
  }

  :global(html[data-theme="dark"]) .chat-bubble :global(code) {
    background: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme="dark"]) .chat-input-area {
    border-top-color: #313244;
  }

  :global(html[data-theme="dark"]) #chat-input {
    border-color: #45475a;
  }

  :global(html[data-theme="dark"]) #chat-input:focus {
    box-shadow: 0 0 0 3px rgba(203, 166, 247, 0.15);
  }

  /* ===== Mobile ===== */
  @media (max-width: 640px) {
    #chat-fab {
      bottom: 16px;
      right: 16px;
      width: 48px;
      height: 48px;
    }

    #chat-window {
      top: 0;
      width: 100vw;
      border-left: none;
    }
  }

  /* ===== Tablet ===== */
  @media (min-width: 641px) and (max-width: 900px) {
    #chat-window {
      width: 360px;
    }
  }

  /* ===== Scrollbar ===== */
  .chat-messages::-webkit-scrollbar {
    width: 5px;
  }

  .chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.12);
    border-radius: 3px;
  }

  :global(html[data-theme="dark"]) .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.12);
  }
</style>

<script>
  import { setupChatWidget } from "@/shared/scripts/chat-widget";

  function init() {
    setupChatWidget();
  }

  document.addEventListener("astro:page-load", init);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
