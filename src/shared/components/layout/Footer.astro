---
import { Github, Linkedin, Mail } from "lucide-astro";
import { AUTHOR_EMAIL, AUTHOR_GITHUB, AUTHOR_LINKEDIN } from "@/shared/config/consts";
import { getLocaleFromPathname, ui, withLocalePath } from "@/shared/i18n/ui";
import { getUrl } from "@/shared/utils/url";

const today = new Date();
const currentLocale = getLocaleFromPathname(Astro.url.pathname);
const t = ui[currentLocale];
const localizedHref = (pathname: string) => getUrl(withLocalePath(pathname, currentLocale));

// Guides has no English counterpart, so English visitors should not be sent
// into Korean-only content.
const siteLinks = [
  { href: localizedHref("/about/"), label: t.about },
  { href: localizedHref("/portfolio/"), label: t.work },
  { href: localizedHref("/resume/"), label: t.resume },
  { href: localizedHref("/blog/"), label: t.blog },
  { href: localizedHref("/library/"), label: t.library },
  ...(currentLocale === "ko" ? [{ href: getUrl("/guides/"), label: t.guides }] : []),
];
---

<footer class="bg-nav text-nav-text body-font py-8 border-t border-nav-border">
  <div class="container mx-auto px-5 flex flex-col items-center">
    <!-- Social Links -->
    <div class="flex space-x-6 mb-6">
      <a
        href={AUTHOR_GITHUB}
        target="_blank"
        rel="noopener noreferrer"
        class="text-nav-text hover:text-accent hover:bg-nav-hover/20 rounded-full p-3 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg"
        title="GitHub"
      >
        <Github class="w-6 h-6" />
      </a>

      <a
        href={AUTHOR_LINKEDIN}
        target="_blank"
        rel="noopener noreferrer"
        class="text-nav-text hover:text-accent hover:bg-nav-hover/20 rounded-full p-3 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg"
        title="LinkedIn"
      >
        <Linkedin class="w-6 h-6" />
      </a>

      <a
        href={`mailto:${AUTHOR_EMAIL}`}
        class="text-nav-text hover:text-accent hover:bg-nav-hover/20 rounded-full p-3 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg"
        title="Email"
      >
        <Mail class="w-6 h-6" />
      </a>
    </div>

    <!-- Site Links — the header stays slim, so everything stays reachable here -->
    <nav class="text-nav-text flex flex-wrap justify-center gap-x-5 gap-y-2 mb-4" aria-label="Site">
      {
        siteLinks.map((link) => (
          <a
            href={link.href}
            class="text-nav-text hover:text-accent text-sm transition-colors duration-200"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Policy Links. Only written in Korean, but a privacy policy has to stay
         reachable from every page, so this one link is not locale-gated. -->
    <div class="text-nav-text flex flex-wrap justify-center gap-4 mb-4">
      <a
        href={getUrl("/privacy")}
        class="text-nav-text hover:text-accent text-sm transition-colors duration-200 underline"
        hreflang="ko"
      >
        Privacy
      </a>
    </div>

    <!-- Copyright -->
    <div class="text-sm text-center">
      <p>&copy; {today.getFullYear()} KIM DEOG HWAN. All rights reserved.</p>
    </div>
  </div>
</footer>
