---
import { Linkedin, Mail } from "lucide-astro";
import { AUTHOR_EMAIL, AUTHOR_LINKEDIN } from "@/shared/config/consts";

interface Props {
  /** data-cta-section 값 (전환 지점 구분용) */
  ctaSection: string;
  /** 바깥 여백 등 배치용 추가 클래스 */
  class?: string;
}

const { ctaSection, class: className = "" } = Astro.props;
const mailto = `mailto:${AUTHOR_EMAIL}`;
---

<div class={`contact-cta ${className}`}>
  <div>
    <p class="contact-cta__title">협업/의뢰 문의는 여기로 보내주세요</p>
    <p class="contact-cta__desc">빠른 답장은 LinkedIn DM, 상세 논의는 이메일이 가장 효율적입니다.</p>
  </div>
  <div class="contact-cta__actions">
    <a
      href={AUTHOR_LINKEDIN}
      target="_blank"
      rel="noopener noreferrer"
      data-cta-track
      data-cta-name="contact_linkedin"
      data-cta-section={ctaSection}
      class="contact-cta__btn contact-cta__btn--ghost"
    >
      <Linkedin size={16} />
      LinkedIn DM
    </a>
    <a
      href={mailto}
      data-cta-track
      data-cta-name="contact_email"
      data-cta-section={ctaSection}
      class="contact-cta__btn contact-cta__btn--primary"
    >
      <Mail size={16} />
      이메일 문의
    </a>
  </div>
</div>

<style>
  /* Tailwind 토큰이 있으면 그대로 쓰고, 없으면(about.astro 등 독립 페이지) 자체 팔레트로 폴백 */
  .contact-cta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--color-background-lighter, var(--line, #faf5ff));
    border-radius: 1rem;
    background: var(--color-background-light, var(--surface, #f9fafb));
  }

  @media (min-width: 768px) {
    .contact-cta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem;
    }
  }

  .contact-cta__title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text, var(--ink, #1a1a2e));
  }

  .contact-cta__desc {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    color: var(--color-text-light, var(--muted, #4a5568));
  }

  .contact-cta__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .contact-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: 0.75rem;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    text-decoration: none;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .contact-cta__btn--ghost {
    border: 1px solid var(--color-background-lighter, var(--line, #faf5ff));
    background: var(--color-background, var(--bg, #ffffff));
    color: var(--color-text, var(--ink, #1a1a2e));
  }

  .contact-cta__btn--ghost:hover {
    border-color: var(--color-primary, var(--accent, #7c3aed));
    color: var(--color-primary, var(--accent, #7c3aed));
  }

  .contact-cta__btn--primary {
    background: var(--color-primary, var(--accent, #7c3aed));
    color: var(--color-on-primary, #ffffff);
  }

  .contact-cta__btn--primary:hover {
    background: var(--color-primary-light, var(--accent-soft, #a78bfa));
  }
</style>
