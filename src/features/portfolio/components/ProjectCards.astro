---
import { Award, ExternalLink, Github, Lock } from "lucide-astro";
import { getOrderedLinks, projects } from "@/features/portfolio/data/projects";

interface Props {
  ctaSection?: string;
}

const { ctaSection = "portfolio_project_cards" } = Astro.props;

const iconMap = {
  github: Github,
  external: ExternalLink,
  lock: Lock,
};
---

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
  {
    projects.map((project) => (
      <article
        class={`group flex flex-col bg-background-light rounded-2xl border ${project.borderColor} dark:border-background-lighter overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300`}
      >
        <div class={`h-1.5 w-full bg-linear-to-r ${project.gradient} dark:opacity-75`} />

        {project.screenshot && (
          <div class="overflow-hidden">
            <img
              src={project.screenshot}
              alt={`${project.title} 스크린샷`}
              class="w-full h-40 object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        )}

        <div class="flex flex-col flex-1 p-5">
          <p class="text-xs font-semibold text-primary mb-1.5">{project.role}</p>
          <h3 class="text-lg font-bold text-text mb-2 group-hover:text-primary transition-colors">
            {project.title}
          </h3>
          <span class="inline-flex items-center gap-1.5 self-start px-2.5 py-1 mb-3 bg-background border border-background-lighter text-text-light text-xs font-semibold rounded-full">
            {project.featured && <Award class="w-3.5 h-3.5" />}
            {project.highlight}
          </span>
          <p class="text-sm text-text-light leading-relaxed mb-4">{project.description}</p>

          <div class="flex flex-wrap gap-1.5 mb-4">
            {project.tags.map((tag) => (
              <span class="px-2.5 py-1 bg-background-muted text-text-muted text-xs font-medium rounded-full">
                {tag}
              </span>
            ))}
          </div>

          <div class="flex flex-wrap items-center gap-2 mt-auto">
            {getOrderedLinks(project.links).map((link) => {
              const Icon = iconMap[link.icon];
              return (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-cta-track
                  data-cta-name={`project_${project.title}_${link.label}`}
                  data-cta-section={ctaSection}
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-background border border-background-lighter hover:border-primary text-text hover:text-primary text-xs font-semibold transition-all duration-200 hover:-translate-y-0.5"
                >
                  <Icon class="w-3.5 h-3.5" />
                  {link.label}
                </a>
              );
            })}
          </div>
        </div>
      </article>
    ))
  }
</div>
