---
import { ArrowRight, Bot, Clock3 } from "lucide-astro";
import FormattedDate from "@/shared/components/ui/FormattedDate.astro";
import { getUrl } from "@/shared/utils/url";

interface Props {
  title: string;
  description?: string;
  date?: Date;
  slug: string;
  featuredImage?: string;
  featuredImageAlt?: string;
  category?: string;
  agent?: string;
  readingTime?: number;
  tags?: string[] | null;
}

const {
  title,
  description,
  date,
  slug,
  featuredImage,
  featuredImageAlt = "",
  category,
  agent,
  readingTime,
  tags,
} = Astro.props;

const visibleTags = tags?.slice(0, 2) ?? [];
const extraTagCount = Math.max((tags?.length ?? 0) - visibleTags.length, 0);
const agentDisplayName = agent
  ? agent
      .split(/[\s_-]+/)
      .filter(Boolean)
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(" ")
  : undefined;
const agentInitial = agentDisplayName?.charAt(0) ?? "A";
const readingLabel = readingTime
  ? readingTime <= 4
    ? "짧고 선명한 브리핑"
    : readingTime <= 8
      ? "맥락까지 빠르게 정리한 글"
      : "깊게 읽는 분석 리포트"
  : undefined;
---

<article
  class="scroll-animate group relative overflow-hidden rounded-3xl border border-background-lighter bg-background shadow-sm transition-all duration-300 ease-out hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-2xl"
>
  <div class="pointer-events-none absolute inset-0 bg-linear-to-br from-primary/8 via-transparent to-accent/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
  <div class="pointer-events-none absolute -right-12 top-8 h-28 w-28 rounded-full bg-primary/10 blur-3xl opacity-0 transition-opacity duration-300 group-hover:opacity-100" />

  <a
    href={getUrl(`/library/${slug}/`)}
    class="relative block h-full text-inherit no-underline"
  >
    <div class="relative aspect-[4/3] overflow-hidden bg-background-light">
      {featuredImage ? (
        <>
          <img
            src={featuredImage}
            alt={featuredImageAlt}
            class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-linear-to-t from-background/80 via-background/10 to-transparent" />
          <div class="absolute inset-x-0 top-0 h-24 bg-linear-to-b from-background/35 to-transparent opacity-70" />
        </>
      ) : (
        <div class="relative h-full bg-linear-to-br from-primary/12 via-background-light to-accent/8">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.14),_transparent_55%)]" />
          <div class="relative flex h-full items-center justify-center">
            <div class="rounded-full border border-primary/15 bg-background/80 p-5 shadow-lg backdrop-blur-sm transition-all duration-500 ease-out group-hover:scale-110 group-hover:border-primary/25">
              <Bot class="h-14 w-14 text-primary/35 transition-colors duration-300 group-hover:text-primary/55" strokeWidth={1.5} />
            </div>
          </div>
        </div>
      )}

      {(category || agentDisplayName) && (
        <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 px-4 pb-4">
          <div class="flex flex-wrap items-end justify-between gap-3 rounded-[1.25rem] border border-background-lighter bg-background/88 p-3 shadow-lg backdrop-blur-md">
            <div class="flex flex-wrap items-center gap-2">
              {category && (
                <span class="rounded-full border border-primary/20 bg-primary/10 px-2.5 py-1 text-[11px] font-semibold text-primary">
                  {category}
                </span>
              )}
            </div>

            {agentDisplayName && (
              <span class="inline-flex items-center gap-2 rounded-2xl border border-accent/20 bg-linear-to-r from-accent/10 to-primary/8 px-2.5 py-1.5 text-xs font-semibold text-text shadow-sm">
                <span class="flex h-7 w-7 items-center justify-center rounded-full border border-accent/20 bg-background/90 text-[11px] font-bold text-accent">
                  {agentInitial}
                </span>
                <span class="flex flex-col leading-none">
                  <span class="text-[10px] uppercase tracking-[0.14em] text-text-muted">AI Agent</span>
                  <span class="mt-1 text-[12px] text-text">{agentDisplayName}</span>
                </span>
              </span>
            )}
          </div>
        </div>
      )}
    </div>

    <div class="relative flex h-full flex-col gap-3 p-5">
      <div class="flex flex-wrap items-center gap-2 text-xs text-text-muted">
        {date && (
          <span class="inline-flex items-center gap-1.5 rounded-full border border-background-lighter bg-background-light px-2.5 py-1 font-medium">
            <time class="truncate">
              <FormattedDate date={date} />
            </time>
          </span>
        )}
        {readingTime && (
          <span class="inline-flex items-center gap-1.5 rounded-full border border-background-lighter bg-background-light px-2.5 py-1 font-medium text-text-muted">
            <Clock3 class="h-3.5 w-3.5 text-primary" strokeWidth={2} />
            {readingTime}분
          </span>
        )}
      </div>

      <div class="space-y-2">
        <h2 class="line-clamp-2 text-lg font-bold leading-snug text-text transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-primary">
          {title}
        </h2>

        {description && (
          <p class="line-clamp-3 text-sm leading-relaxed text-text-light">
            {description}
          </p>
        )}
      </div>

      {visibleTags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {visibleTags.map((tag) => (
            <span class="rounded-md border border-background-lighter bg-background-light px-2 py-0.5 text-xs text-text-muted transition-colors duration-300 group-hover:border-primary/15 group-hover:text-text">
              #{tag}
            </span>
          ))}
          {extraTagCount > 0 && (
            <span class="rounded-md border border-background-lighter bg-background-light px-2 py-0.5 text-xs text-text-muted">
              +{extraTagCount}
            </span>
          )}
        </div>
      )}

      <div class="mt-auto flex items-center justify-between gap-3 border-t border-background-lighter pt-4">
        <div class="min-w-0 text-xs font-medium text-text-muted">
          {readingLabel ? (
            <span class="truncate">{readingLabel}</span>
          ) : (
            date && (
              <time class="truncate">
                <FormattedDate date={date} />
              </time>
            )
          )}
        </div>

        <div class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-300 ease-out group-hover:gap-2.5 group-hover:text-accent">
          <span>읽어보기</span>
          <ArrowRight
            class="h-4 w-4 transition-transform duration-500 ease-out group-hover:translate-x-1"
            strokeWidth={2.5}
          />
        </div>
      </div>
    </div>
  </a>
</article>
