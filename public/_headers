# 보안 헤더 (모든 경로)
/*
  # HTTPS 강제 (1년, 서브도메인 포함, preload)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Content Security Policy (XSS 방어)
  # Google 서비스 (GTM, GA4) + Giscus + Vanta.js + Cloudflare
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://giscus.app https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://*.google.com https://giscus.app; frame-src https://giscus.app https://www.youtube.com https://www.google.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests

  # 클릭재킹 방어
  X-Frame-Options: DENY

  # MIME 타입 스니핑 방지
  X-Content-Type-Options: nosniff

  # Referrer 정책
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy (불필요한 기능 비활성화)
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()

# HTML 페이지 — 브라우저에 남기지 않는다.
# 자산 파일명은 빌드마다 해시가 바뀌는데 HTML을 캐시해두면, 배포 직후
# 재방문자의 브라우저가 옛 HTML을 그대로 쓰면서 사라진 해시 파일을 요청해
# 스타일이 통째로 깨진다. 나머지 경로는 Cloudflare 기본값이 이미 max-age=0.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# 루트 페이지
/
  Cache-Control: public, max-age=0, must-revalidate

# API 엔드포인트 (캐시 안함)
/api/*
  Cache-Control: no-cache, no-store, must-revalidate

# Astro 빌드 파일 (긴 캐시 - 파일명에 해시 포함)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# 폰트 파일 (긴 캐시)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# 이미지 파일 (1개월 캐시)
/images/*
  Cache-Control: public, max-age=2592000, immutable

# 정적 파일 (favicon, manifest 등)
/*.ico
  Cache-Control: public, max-age=86400, must-revalidate

/*.json
  Cache-Control: public, max-age=86400, must-revalidate

/*.xml
  Cache-Control: public, max-age=86400, must-revalidate

/*.txt
  Cache-Control: public, max-age=86400, must-revalidate
